---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="The Magic — Formic Platform"
  description="PLC reliability meets software intelligence. Cortex and Core — the hybrid platform behind every Formic system."
  ogTitle="The Magic — Formic Platform"
  ogDescription="Cortex and Core — PLC reliability with software intelligence."
>
  <link rel="canonical" href="https://formic.co/magic" slot="head" />

  <style is:global slot="head">
/* ── Magic page ── distinct layout language vs. rest of site ── */
.mg-bg{background:var(--black);color:var(--white)}
.mg-bg .mg-mono,.mg-bg [data-tag]{color:rgba(255,145,0,.85)}

/* breadcrumb */
.mg-bc{padding:88px 80px 0;font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,245,241,.5);background:var(--black)}
.mg-bc a{color:rgba(240,245,241,.5);text-decoration:none}
.mg-bc a:hover{color:var(--orange)}
.mg-bc .sep{margin:0 10px;color:rgba(240,245,241,.2)}

/* HERO — bold typographic, investor-grade, cursor-interactive */
.mg-hero{position:relative;background:var(--black);color:var(--white);padding:48px 80px 120px;overflow:hidden;min-height:88vh}
#mg-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none}
.mg-hero .mg-inner{position:relative;z-index:2;max-width:1280px;margin:0 auto}

/* Cursor-following spotlight across entire Magic page */
.mg-spot{position:fixed;top:0;left:0;width:720px;height:720px;border-radius:50%;background:radial-gradient(circle,rgba(255,145,0,.10) 0%,rgba(255,145,0,.04) 35%,transparent 70%);transform:translate3d(var(--mx,50vw),var(--my,50vh),0) translate(-50%,-50%);pointer-events:none;z-index:1;mix-blend-mode:screen;transition:opacity .3s}
.mg-mono{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--orange);margin-bottom:28px;display:flex;align-items:center;gap:14px}
.mg-mono::before{content:"";width:36px;height:1px;background:var(--orange)}
.mg-h1{font-family:var(--sans);font-weight:500;font-size:clamp(64px,9vw,156px);line-height:.92;letter-spacing:-.035em;color:var(--white);margin-bottom:48px}
.mg-h1 .em{color:var(--orange);font-style:normal;display:block}
.mg-lede{font-size:20px;font-weight:300;line-height:1.6;color:rgba(240,245,241,.65);max-width:680px;margin-bottom:40px}
.mg-meta{display:flex;gap:48px;flex-wrap:wrap;font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase}
.mg-meta-item{display:flex;flex-direction:column;gap:6px}
.mg-meta-key{color:rgba(240,245,241,.4)}
.mg-meta-val{color:var(--orange);font-size:14px;letter-spacing:.12em}

/* Numbered SECTION pattern — diagonal split, big numeral, narrow text column */
.mg-section{position:relative;padding:140px 80px;border-top:1px solid rgba(240,245,241,.08);background:var(--black);color:var(--white)}
.mg-section.alt{background:#0d181a}
.mg-section .mg-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:140px 1fr 1fr;gap:60px;align-items:start}
.mg-num{font-family:var(--mono);font-size:14px;font-weight:500;letter-spacing:.22em;color:rgba(240,245,241,.4);position:sticky;top:120px}
.mg-num strong{color:var(--orange);font-weight:500;font-size:48px;letter-spacing:-.02em;display:block;margin-bottom:16px;font-family:var(--sans)}
.mg-section h2{font-family:var(--sans);font-weight:500;font-size:clamp(48px,5.5vw,88px);line-height:.96;letter-spacing:-.025em;color:var(--white);margin-bottom:32px}
.mg-section h2 .em{color:var(--orange);font-style:normal;display:block}
.mg-section .mg-body{font-size:18px;font-weight:300;line-height:1.7;color:rgba(240,245,241,.7);margin-bottom:24px}

/* Capability list — interactive hover reveal */
.mg-caps{display:flex;flex-direction:column;border-top:1px solid rgba(240,245,241,.08)}
.mg-cap{padding:22px 0;border-bottom:1px solid rgba(240,245,241,.08);display:grid;grid-template-columns:36px 1fr;gap:16px;align-items:start;cursor:none;transition:padding-left .25s}
.mg-cap:hover{padding-left:8px}
.mg-cap-num{font-family:var(--mono);font-size:11px;letter-spacing:.18em;color:rgba(240,245,241,.4);padding-top:4px}
.mg-cap-body{display:flex;flex-direction:column;gap:6px}
.mg-cap h3{font-family:var(--sans);font-size:18px;font-weight:500;letter-spacing:-.01em;color:var(--white);margin:0}
.mg-cap p{font-size:14px;font-weight:300;line-height:1.6;color:rgba(240,245,241,.55);max-height:0;opacity:0;overflow:hidden;transition:max-height .35s ease,opacity .25s ease,margin .35s ease;margin:0}
.mg-cap:hover p{max-height:160px;opacity:1;margin-top:6px}
.mg-cap:hover h3{color:var(--orange)}

/* Spec strip — terminal/console aesthetic */
.mg-specs{font-family:var(--mono);font-size:12px;line-height:1.7;color:rgba(255,145,0,.85);background:rgba(255,145,0,.04);border:1px solid rgba(255,145,0,.18);padding:24px 28px;margin-top:36px}
.mg-specs .row{display:grid;grid-template-columns:120px 1fr;gap:18px;padding:6px 0;border-bottom:1px dashed rgba(255,145,0,.12)}
.mg-specs .row:last-child{border-bottom:none}
.mg-specs .k{color:rgba(240,245,241,.4);letter-spacing:.16em;text-transform:uppercase;font-size:10px;padding-top:2px}
.mg-specs .v{color:var(--white);font-size:13px}
.mg-specs .v em{color:var(--orange);font-style:normal}

/* Architecture stack — interactive layered diagram */
.mg-stack-section{padding:160px 80px;background:#0a1517;border-top:1px solid rgba(240,245,241,.08);border-bottom:1px solid rgba(240,245,241,.08)}
.mg-stack-section .mg-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1.1fr;gap:80px;align-items:center}
.mg-stack-text h2{font-family:var(--sans);font-weight:500;font-size:clamp(40px,4.5vw,72px);line-height:.98;letter-spacing:-.025em;color:var(--white);margin-bottom:24px}
.mg-stack-text h2 .em{color:var(--orange);font-style:normal}
.mg-stack-text p{font-size:17px;font-weight:300;line-height:1.7;color:rgba(240,245,241,.65);margin-bottom:18px}
.mg-stack{display:flex;flex-direction:column;gap:8px;padding:28px;background:rgba(255,145,0,.02);border:1px solid rgba(255,145,0,.12)}
.mg-layer{position:relative;padding:24px 28px;background:rgba(240,245,241,.03);border:1px solid rgba(240,245,241,.08);cursor:none;transition:border-color .3s,background .3s}
.mg-layer::before{content:attr(data-layer);position:absolute;top:24px;right:28px;font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:rgba(240,245,241,.3);text-transform:uppercase}
.mg-layer:hover,.mg-layer.is-hot{border-color:var(--orange);background:rgba(255,145,0,.06)}
.mg-layer-title{font-family:var(--sans);font-size:18px;font-weight:500;color:var(--white);margin-bottom:6px;letter-spacing:-.01em}
.mg-layer-desc{font-family:var(--mono);font-size:11px;line-height:1.6;color:rgba(240,245,241,.5);max-height:0;opacity:0;overflow:hidden;transition:max-height .35s ease,opacity .25s ease,margin .35s ease}
.mg-layer:hover .mg-layer-desc,.mg-layer.is-hot .mg-layer-desc{max-height:120px;opacity:1;margin-top:10px}
.mg-layer:hover .mg-layer-title,.mg-layer.is-hot .mg-layer-title{color:var(--orange)}

/* Stats — interactive technical claims (count up on hover) */
.mg-stats{padding:120px 80px;background:var(--black);color:var(--white)}
.mg-stats .mg-inner{max-width:1280px;margin:0 auto}
.mg-stats h2{font-family:var(--sans);font-size:clamp(36px,4vw,60px);font-weight:500;letter-spacing:-.025em;line-height:1;margin-bottom:48px}
.mg-stats h2 .em{color:var(--orange);font-style:normal}
.mg-stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(240,245,241,.08)}
.mg-stat{background:#0d181a;padding:48px 32px;cursor:none;transition:background .3s}
.mg-stat:hover{background:#15252a}
.mg-stat-num{font-family:var(--sans);font-size:64px;font-weight:500;color:var(--white);line-height:.95;letter-spacing:-.025em;margin-bottom:14px;display:block}
.mg-stat-num em{color:var(--orange);font-style:normal;font-size:.6em;font-weight:500;letter-spacing:.01em;margin-left:4px}
.mg-stat-lbl{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,245,241,.5)}

/* Robot brands rotator (Core section) */
.mg-brands{display:flex;gap:0;border-top:1px solid rgba(240,245,241,.08);border-bottom:1px solid rgba(240,245,241,.08);margin-top:36px;flex-wrap:wrap}
.mg-brand{flex:1 1 25%;padding:28px 18px;text-align:center;font-family:var(--sans);font-size:18px;font-weight:500;letter-spacing:-.005em;color:rgba(240,245,241,.4);transition:color .25s,background .25s;cursor:none;border-right:1px solid rgba(240,245,241,.08)}
.mg-brand:last-child{border-right:none}
.mg-brand:hover{color:var(--orange);background:rgba(255,145,0,.04)}

/* Closing CTA — investor flavor */
.mg-cta{padding:140px 80px;background:var(--orange);text-align:center}
.mg-cta h2{font-family:var(--sans);font-size:clamp(48px,6vw,88px);font-weight:500;line-height:1;letter-spacing:-.025em;color:var(--black);margin-bottom:24px}
.mg-cta p{font-size:17px;color:rgba(9,21,23,.6);max-width:540px;margin:0 auto 40px;line-height:1.6}
.mg-cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

@media(max-width:900px){
  .mg-bc{padding:80px 24px 0}
  .mg-hero{padding:24px 24px 80px}
  .mg-section,.mg-stack-section,.mg-stats,.mg-cta{padding:80px 24px}
  .mg-section .mg-inner{grid-template-columns:1fr;gap:24px}
  .mg-num{position:static}
  .mg-stack-section .mg-inner{grid-template-columns:1fr;gap:32px}
  .mg-stat-grid{grid-template-columns:repeat(2,1fr)}
  .mg-brand{flex:1 1 50%}
  .mg-meta{gap:24px}
}
  </style>

<div class="mg-bc">
  <a href="/">Home</a><span class="sep">/</span>The Magic
</div>

<div class="mg-spot" aria-hidden="true"></div>

<!-- HERO -->
<section class="mg-hero">
  <canvas id="mg-canvas" aria-hidden="true"></canvas>
  <div class="mg-inner">
    <div class="mg-mono">00 / Formic Platform</div>
    <h1 class="mg-h1">PLC Reliability.<span class="em">Software Intelligence.</span></h1>
    <p class="mg-lede">Formic's hybrid architecture pairs deterministic industrial control with a modern software layer. Cortex and Core run together as one system — your automation gets smarter over time, never obsolete.</p>
    <div class="mg-meta">
      <div class="mg-meta-item"><span class="mg-meta-key">Built on</span><span class="mg-meta-val">Industrial PLC + Software</span></div>
      <div class="mg-meta-item"><span class="mg-meta-key">Robots supported</span><span class="mg-meta-val">KUKA · ABB · FANUC · Doosan</span></div>
      <div class="mg-meta-item"><span class="mg-meta-key">Update cadence</span><span class="mg-meta-val">Continuous OTA</span></div>
    </div>
  </div>
</section>

<!-- 01 / CORTEX -->
<section class="mg-section">
  <div class="mg-inner">
    <div class="mg-num"><strong>01</strong>Cortex<br>Software</div>
    <div>
      <h2>The brain across<span class="em">every Formic system.</span></h2>
      <p class="mg-body">Cortex is the intelligence layer that ties every cell, line, and site together. Fleet visibility, remote diagnostics, real-time analytics, and continuous OTA upgrades — your operators and our support engineers see the same live data, everywhere.</p>
      <div class="mg-specs">
        <div class="row"><span class="k">Layer</span><span class="v">Software intelligence — runs alongside Core</span></div>
        <div class="row"><span class="k">Telemetry</span><span class="v"><em>Real-time</em> OEE, throughput, cycle time</span></div>
        <div class="row"><span class="k">Updates</span><span class="v">OTA, backward-compatible across fleet</span></div>
        <div class="row"><span class="k">Connectivity</span><span class="v">Encrypted remote diagnostics, MES/ERP APIs</span></div>
      </div>
    </div>
    <div class="mg-caps">
      <div class="mg-cap">
        <span class="mg-cap-num">001</span>
        <div class="mg-cap-body"><h3>Fleet visibility</h3><p>Real-time OEE, throughput, and cycle-time analytics across every cell, line, and facility — accessible to your team, not gated behind a vendor portal.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">002</span>
        <div class="mg-cap-body"><h3>Remote diagnostics</h3><p>Encrypted, full root-cause tooling. Most issues are resolved without a site visit — and your maintenance team sees what we see.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">003</span>
        <div class="mg-cap-body"><h3>Bilingual operator HMI</h3><p>An operator-friendly touch interface on every machine. English and Spanish out of the box. Trainable in minutes.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">004</span>
        <div class="mg-cap-body"><h3>Continuous releases</h3><p>Backward-compatible OTA feature releases — your first system benefits from everything we ship to your hundredth.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">005</span>
        <div class="mg-cap-body"><h3>Integrations</h3><p>Read/write APIs for MES, ERP, SCADA. Production data flows where your team already runs it — no re-tooling required.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- 02 / CORE -->
<section class="mg-section alt">
  <div class="mg-inner">
    <div class="mg-num"><strong>02</strong>Core<br>Industrial control</div>
    <div>
      <h2>Industrial control,<span class="em">standardized.</span></h2>
      <p class="mg-body">Core delivers deterministic, safety-rated PLC motion on proven industrial hardware. The same reliability your maintenance team already knows — KUKA, ABB, FANUC, Doosan, Rockwell, Siemens — now with software visibility on top.</p>
      <div class="mg-brands">
        <div class="mg-brand">KUKA</div>
        <div class="mg-brand">ABB</div>
        <div class="mg-brand">FANUC</div>
        <div class="mg-brand">Doosan</div>
      </div>
    </div>
    <div class="mg-caps">
      <div class="mg-cap">
        <span class="mg-cap-num">001</span>
        <div class="mg-cap-body"><h3>Hard-real-time motion</h3><p>Deterministic PLC control on Rockwell Automation and Siemens hardware — the industrial-grade backbone your maintenance team already trusts.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">002</span>
        <div class="mg-cap-body"><h3>Modular architecture</h3><p>Standardized "Lego-block" modules across every deployment. Same building blocks, every customer, every site.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">003</span>
        <div class="mg-cap-body"><h3>Multi-vendor robot OS</h3><p>KUKA, ABB, FANUC, and Doosan robots unified under one control layer. Pick the brand that fits the application — keep the same platform.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">004</span>
        <div class="mg-cap-body"><h3>Safety-rated by default</h3><p>Stops, light curtains, and area scanners are standard. Compliance is built into the cell, not bolted on.</p></div>
      </div>
      <div class="mg-cap">
        <span class="mg-cap-num">005</span>
        <div class="mg-cap-body"><h3>Backward compatibility</h3><p>Maintained across every fleet release. Five-year-old Formic systems run the same control core as the systems we're shipping today.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- ARCHITECTURE STACK -->
<section class="mg-stack-section">
  <div class="mg-inner">
    <div class="mg-stack-text">
      <div class="mg-mono">03 / Architecture</div>
      <h2>Two layers,<span class="em">one system.</span></h2>
      <p>Most automation platforms force a tradeoff: rock-solid PLC control with no software smarts, or modern software on top of brittle integration. Formic doesn't make you choose.</p>
      <p>Cortex and Core run together. Each layer does what it does best. The result is a platform that scales across every site without compromise — and a fleet that gets better, not older.</p>
    </div>
    <div class="mg-stack">
      <div class="mg-layer is-hot" data-layer="04">
        <div class="mg-layer-title">Operator HMI</div>
        <div class="mg-layer-desc">Bilingual touchscreen on every cell. Status, fault recovery, simple cycle controls.</div>
      </div>
      <div class="mg-layer" data-layer="03">
        <div class="mg-layer-title">Cortex · Software intelligence</div>
        <div class="mg-layer-desc">Fleet management, analytics, remote diagnostics, OTA delivery. The brain that connects every site.</div>
      </div>
      <div class="mg-layer" data-layer="02">
        <div class="mg-layer-title">Core · Control layer</div>
        <div class="mg-layer-desc">Hard-real-time PLC motion. Deterministic, safety-rated, industrial-grade.</div>
      </div>
      <div class="mg-layer" data-layer="01">
        <div class="mg-layer-title">Hardware · Robots &amp; PLCs</div>
        <div class="mg-layer-desc">KUKA, ABB, FANUC, Doosan, Rockwell, Siemens. The proven hardware your maintenance team already knows.</div>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="mg-stats">
  <div class="mg-inner">
    <div class="mg-mono">04 / By the numbers</div>
    <h2>Reliability and reach,<span class="em">measured.</span></h2>
    <div class="mg-stat-grid">
      <div class="mg-stat"><span class="mg-stat-num" data-count-to="4" data-suffix="">4</span><span class="mg-stat-lbl">Robot brands unified</span></div>
      <div class="mg-stat"><span class="mg-stat-num" data-count-to="2" data-suffix=" wks">2 wks</span><span class="mg-stat-lbl">Avg. deployment time</span></div>
      <div class="mg-stat"><span class="mg-stat-num" data-count-to="100" data-suffix="%">100%</span><span class="mg-stat-lbl">OTA, backward-compatible</span></div>
      <div class="mg-stat"><span class="mg-stat-num" data-count-to="24" data-suffix="/7">24/7</span><span class="mg-stat-lbl">Remote diagnostics</span></div>
    </div>
  </div>
</section>

<!-- CTA — investor flavor -->
<section class="mg-cta">
  <div class="mg-mono" style="color:rgba(9,21,23,.5);justify-content:center;display:flex">05 / Next steps</div>
  <h2>Book a platform<br>deep dive.</h2>
  <p>Walk through the Cortex + Core architecture with our engineering team. Investor and prospective customer briefings welcome.</p>
  <div class="mg-cta-btns">
    <a href="mailto:sales@formic.co" class="btn-ctadark">Schedule a Briefing</a>
    <a href="/" class="btn-ctawh">Back to Home</a>
  </div>
</section>

  <script is:inline slot="scripts">
// Magic page interactives
(function(){
  // Cursor-following spotlight across the page
  document.addEventListener('mousemove',e=>{
    document.documentElement.style.setProperty('--mx',e.clientX+'px');
    document.documentElement.style.setProperty('--my',e.clientY+'px');
  });

  // Hero particle field — orange nodes that bend toward the cursor
  const c=document.getElementById('mg-canvas');
  if(c){
    const ctx=c.getContext('2d');
    let W=0,H=0,nodes=[],mouse={x:-9999,y:-9999};
    function resize(){
      const r=c.getBoundingClientRect();
      W=c.width=r.width;H=c.height=r.height;
      c.style.width=W+'px';c.style.height=H+'px';
      nodes=[];
      const cols=Math.max(14,Math.round(W/90));
      const rows=Math.max(8,Math.round(H/90));
      for(let i=0;i<cols;i++)for(let j=0;j<rows;j++){
        const x=(i/(cols-1))*W,y=(j/(rows-1))*H;
        nodes.push({bx:x,by:y,x:x,y:y,r:Math.random()*1.4+.5});
      }
    }
    resize();window.addEventListener('resize',resize);
    c.addEventListener('mousemove',()=>{},{passive:true});
    document.addEventListener('mousemove',e=>{
      const r=c.getBoundingClientRect();
      mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;
    },{passive:true});
    function draw(){
      ctx.clearRect(0,0,W,H);
      const RADIUS=240;
      nodes.forEach(n=>{
        const dx=n.bx-mouse.x,dy=n.by-mouse.y;
        const d=Math.sqrt(dx*dx+dy*dy);
        const f=Math.max(0,RADIUS-d)/RADIUS;
        const ang=Math.atan2(dy,dx);
        const push=f*f*60;
        n.x+=(n.bx+Math.cos(ang)*push-n.x)*.1;
        n.y+=(n.by+Math.sin(ang)*push-n.y)*.1;
        ctx.beginPath();
        ctx.arc(n.x,n.y,n.r+f*2.6,0,Math.PI*2);
        ctx.fillStyle='rgba(255,145,0,'+(0.06+f*.55)+')';
        ctx.fill();
      });
      // Connect nearby nodes
      for(let i=0;i<nodes.length;i+=2){
        for(let j=i+1;j<nodes.length;j+=2){
          const a=nodes[i],b=nodes[j];
          const dx=a.x-b.x,dy=a.y-b.y;
          const d=Math.sqrt(dx*dx+dy*dy);
          if(d<82){
            const adx=a.bx-mouse.x,ady=a.by-mouse.y;
            const af=Math.max(0,RADIUS-Math.sqrt(adx*adx+ady*ady))/RADIUS;
            ctx.beginPath();
            ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
            ctx.strokeStyle='rgba(255,145,0,'+(1-d/82)*(.025+af*.15)+')';
            ctx.lineWidth=.6;ctx.stroke();
          }
        }
      }
      // Lines from cursor to nearest nodes
      nodes.forEach(n=>{
        const dx=n.x-mouse.x,dy=n.y-mouse.y;
        const d=Math.sqrt(dx*dx+dy*dy);
        if(d<140){
          ctx.beginPath();
          ctx.moveTo(mouse.x,mouse.y);ctx.lineTo(n.x,n.y);
          ctx.strokeStyle='rgba(255,145,0,'+(1-d/140)*.45+')';
          ctx.lineWidth=.8;ctx.stroke();
        }
      });
      requestAnimationFrame(draw);
    }
    draw();
  }

  // Stat counters — count up on hover
  const stats=document.querySelectorAll('.mg-stat-num[data-count-to]');
  const ease=t=>1-Math.pow(1-t,3);
  function run(el){
    const target=parseFloat(el.dataset.countTo)||0;
    const prefix=el.dataset.prefix||'';
    const suffix=el.dataset.suffix||'';
    const dur=1100,start=performance.now();
    if(el._raf)cancelAnimationFrame(el._raf);
    function step(now){
      const t=Math.min(1,(now-start)/dur);
      const v=Math.round(target*ease(t));
      el.textContent=prefix+v+suffix;
      if(t<1)el._raf=requestAnimationFrame(step);
    }
    el._raf=requestAnimationFrame(step);
  }
  stats.forEach(s=>{
    const cell=s.closest('.mg-stat')||s;
    cell.addEventListener('mouseenter',()=>run(s));
  });

  // Architecture stack — clicking/hovering a layer makes it the "hot" one (others fade)
  const layers=document.querySelectorAll('.mg-layer');
  layers.forEach(l=>{
    l.addEventListener('mouseenter',()=>{
      layers.forEach(x=>x.classList.remove('is-hot'));
      l.classList.add('is-hot');
    });
  });
})();
  </script>
</Layout>
