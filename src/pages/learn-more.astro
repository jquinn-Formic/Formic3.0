---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Learn More — Formic"
  description="News, downloads, mission, and careers — everything beyond the product, in one place."
  ogTitle="Learn More — Formic"
  ogDescription="Mission, news, careers, downloads — Formic beyond the product."
>
  <link rel="canonical" href="https://formic.co/learn-more" slot="head" />

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span>Learn More
</div>

<section class="detail-hero">
  <div class="si">
    <div class="slabel" style="color:var(--orange)">Learn More</div>
    <h1>Driving U.S. manufacturing<br><em>forward</em>.</h1>
    <p class="lede">Why Formic exists, what we're building, and how to join us. The mission, the news, the resources, and the open roles — everything beyond the product, in one place.</p>
  </div>
</section>

<section class="detail-block white">
  <div class="db-grid">
    <div class="db-text">
      <div class="db-tag">Mission</div>
      <h2>Accelerate the <em>accessibility</em> of automation.</h2>
      <p>Formic was founded to deliver more capacity, consistency, and reliability to mid-market manufacturing — while reducing cost, downtime, and worker safety issues. Every mid-market manufacturer deserves access to the same robotic automation Fortune 500 companies take for granted, without 18-month deployment timelines or capital risk.</p>
      <p>Founded 2020 in Chicago, IL.</p>
      <a href="/#cta" class="larr">Get in touch →</a>
    </div>
    <div class="db-img"><img src="/Focus-7603.jpg" alt="Formic mission imagery" loading="lazy"/><span class="img-cap">Founded 2020 · Chicago, IL</span></div>
  </div>
</section>

<section class="detail-block dark">
  <div class="db-grid flip">
    <div class="db-img"><img src="/Talos-0095.jpg" alt="Formic in the news" loading="lazy"/><span class="img-cap">Press · Announcements</span></div>
    <div class="db-text">
      <div class="db-tag">News</div>
      <h2>What we're <em>shipping</em>, and<br>who's writing about it.</h2>
      <p>Product launches, customer wins, fundraising milestones, and industry coverage. We post the things that matter — not press for press's sake.</p>
      <ul class="feats">
        <li>Latest product releases and platform milestones</li>
        <li>Customer go-live announcements</li>
        <li>Industry coverage and analyst reports</li>
        <li>Press contact: press@formic.co</li>
      </ul>
      <a href="mailto:press@formic.co" class="larr">Press inquiries →</a>
    </div>
  </div>
</section>

<section class="detail-block lgrey">
  <div class="db-grid">
    <div class="db-text">
      <div class="db-tag">Downloads</div>
      <h2>Datasheets, case studies, <em>and brochures</em>.</h2>
      <p>The resources your team needs to scope a project, build a business case, or share Formic internally — datasheets per solution, case studies per customer, and the full Full Service brochure.</p>
      <ul class="feats">
        <li>Solution datasheets — Palletizing, Case Packing, AMRs, Tending</li>
        <li>Customer case studies — Land O'Frost, Mi Rancho, Mariani, Taffy Town</li>
        <li>Full Service Automation brochure (PDF)</li>
        <li>Technical white papers on hybrid architecture</li>
      </ul>
      <a href="/#cta" class="larr">Request the resource pack →</a>
    </div>
    <div class="db-img"><img src="/Talos-9787.jpg" alt="Formic downloadable resources" loading="lazy"/><span class="img-cap">Datasheets · Case studies · Brochures</span></div>
  </div>
</section>

<section class="detail-block dgrey">
  <div class="db-grid flip">
    <div class="db-img"><img src="/Talos-0143.jpg" alt="Formic careers" loading="lazy"/><span class="img-cap">Hiring across engineering &amp; operations</span></div>
    <div class="db-text">
      <div class="db-tag">Careers</div>
      <h2>Build the operating layer of <em>physical industry</em>.</h2>
      <p>We're hiring across engineering, field service, customer success, and operations. Roles based in Chicago and remote across the U.S. — and we'll relocate the right people.</p>
      <ul class="feats">
        <li>Robotics &amp; controls engineering</li>
        <li>Field Service Engineers (regional, multiple cities)</li>
        <li>Customer success and account management</li>
        <li>Software, platform, and infrastructure engineering</li>
      </ul>
      <a href="mailto:careers@formic.co" class="larr">See open roles →</a>
    </div>
  </div>
</section>

<section class="detail-cta">
  <h2>Help us automate<br><em>American manufacturing</em>.</h2>
  <div class="btn-row">
    <a href="mailto:sales@formic.co" class="btn-ctadark">Talk to Sales</a>
    <a href="mailto:careers@formic.co" class="btn-ctawh">Open Roles</a>
  </div>
</section>
</Layout>
