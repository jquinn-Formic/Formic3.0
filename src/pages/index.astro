  <script is:inline slot="scripts">
function toggleMute(){
  const vid=document.getElementById('heroVid');
  const btn=document.getElementById('muteBtn');
  if(!vid||!btn)return;
  vid.muted=!vid.muted;
  btn.textContent=vid.muted?'Unmute':'Mute';
}

// Stat counter — counts up from 0 on hover
function initCounters(){
  const els=document.querySelectorAll('.stnum[data-count-to]');
  if(!els.length)return;
  const ease=t=>1-Math.pow(1-t,3);
  function run(el){
    const target=parseFloat(el.dataset.countTo)||0;
    const prefix=el.dataset.prefix||'';
    const suffix=el.dataset.suffix||'';
    const dur=1200,start=performance.now();
    if(el._raf)cancelAnimationFrame(el._raf);
    function step(now){
      const t=Math.min(1,(now-start)/dur);
      const v=Math.round(target*ease(t));
      el.textContent=prefix+v+suffix;
      if(t<1)el._raf=requestAnimationFrame(step);
    }
    el._raf=requestAnimationFrame(step);
  }
  els.forEach(el=>{
    const cell=el.closest('.stcell')||el;
    cell.style.cursor='none';
    cell.addEventListener('mouseenter',()=>run(el));
  });
}

// Nav goes light when CTA section is in view
function initNavBottom(){
  const nav=document.getElementById('nav');
  const trigger=document.getElementById('cta');
  if(!nav||!trigger)return;
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>nav.classList.toggle('nav-bottom',e.isIntersecting));
  },{threshold:.15});
  obs.observe(trigger);
}

// Generic horizontal section: each .home-section with a tab strip + track
// Auto-rotates through tabs every ROTATE_MS, pauses on hover/touch over tabs or panel area,
// pauses while section is offscreen, and respects prefers-reduced-motion.
function initHomeSections(){
  document.querySelectorAll('.home-section').forEach(section=>{
    const track=section.querySelector('.hsection-track');
    const tabs=Array.from(section.querySelectorAll('.htab'));
    if(!track||!tabs.length)return;
    const panels=tabs.map(t=>section.querySelector(t.dataset.target)).filter(Boolean);
    const tabsContainer=section.querySelector('.hsection-tabs');
    const ROTATE_MS=6000;
    const reduced=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let activeIdx=0;
    let cycleStart=0;
    let pausedElapsed=0;
    let paused=false;
    let inView=false;
    let timer=null;
    let raf=null;

    function setActiveByIdx(i,resetProgress){
      if(i<0||i>=tabs.length)return;
      activeIdx=i;
      tabs.forEach(x=>x.classList.remove('active'));
      tabs[i].classList.add('active');
      if(resetProgress!==false){
        tabs.forEach(x=>x.style.setProperty('--htab-progress','0%'));
        cycleStart=performance.now();
        pausedElapsed=0;
      }
    }
    function scrollToPanel(panel){
      if(!panel)return;
      const trackRect=track.getBoundingClientRect();
      const panelRect=panel.getBoundingClientRect();
      const left=track.scrollLeft+(panelRect.left-trackRect.left);
      track.scrollTo({left,behavior:'smooth'});
    }
    function clearTimer(){if(timer){clearTimeout(timer);timer=null;}}
    function schedule(remaining){
      clearTimer();
      if(reduced||paused||!inView||tabs.length<2)return;
      timer=setTimeout(()=>{
        const next=(activeIdx+1)%tabs.length;
        setActiveByIdx(next,true);
        scrollToPanel(panels[next]);
        schedule();
      },remaining==null?ROTATE_MS:remaining);
    }
    function tick(){
      raf=requestAnimationFrame(tick);
      if(reduced||!inView)return;
      const now=performance.now();
      const elapsed=paused?pausedElapsed:(now-cycleStart);
      const pct=Math.max(0,Math.min(100,(elapsed/ROTATE_MS)*100));
      tabs[activeIdx].style.setProperty('--htab-progress',pct+'%');
    }
    function pause(){
      if(paused)return;
      paused=true;
      pausedElapsed=performance.now()-cycleStart;
      clearTimer();
    }
    function resume(){
      if(!paused)return;
      paused=false;
      cycleStart=performance.now()-pausedElapsed;
      schedule(Math.max(0,ROTATE_MS-pausedElapsed));
    }

    tabs.forEach((t,i)=>{
      t.addEventListener('click',function(e){
        e.preventDefault();
        setActiveByIdx(i,true);
        scrollToPanel(panels[i]);
        schedule();
      });
    });

    // Pause-on-hover over either the tab strip or the panel area
    [tabsContainer,track].filter(Boolean).forEach(el=>{
      el.addEventListener('mouseenter',pause);
      el.addEventListener('mouseleave',resume);
      el.addEventListener('touchstart',pause,{passive:true});
      el.addEventListener('touchend',resume,{passive:true});
    });

    // Existing IO: when a panel scrolls into the track viewport, mark its tab active
    const obs=new IntersectionObserver(entries=>{
      entries.forEach(e=>{
        if(!e.isIntersecting)return;
        const i=panels.indexOf(e.target);
        if(i>=0&&i!==activeIdx)setActiveByIdx(i,true);
      });
    },{root:track,threshold:.55});
    panels.forEach(p=>obs.observe(p));

    // Only rotate while the section itself is in the viewport
    const sectionObs=new IntersectionObserver(entries=>{
      entries.forEach(e=>{
        inView=e.isIntersecting;
        if(inView){
          if(!raf)raf=requestAnimationFrame(tick);
          if(!paused){cycleStart=performance.now()-pausedElapsed;schedule(Math.max(0,ROTATE_MS-pausedElapsed));}
        }else{
          clearTimer();
        }
      });
    },{threshold:.25});
    sectionObs.observe(section);

    setActiveByIdx(0,true);
  });
}

// Magic section — cursor-following spotlight + particle field, scoped to the section
function initHomeMagic(){
  const section=document.getElementById('magic');
  const canvas=document.getElementById('home-mg-canvas');
  if(!section)return;
  // Spotlight: only active when section is in view; mx/my set on this section, not :root
  const observer=new IntersectionObserver(entries=>{
    entries.forEach(e=>section.classList.toggle('is-cursor-in',e.isIntersecting));
  },{threshold:0});
  observer.observe(section);
  section.addEventListener('mousemove',e=>{
    const r=section.getBoundingClientRect();
    section.style.setProperty('--home-mx',(e.clientX-r.left)+'px');
    section.style.setProperty('--home-my',(e.clientY-r.top)+'px');
  });
  // Particle field
  if(!canvas)return;
  if(window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches)return;
  const ctx=canvas.getContext('2d');
  let W=0,H=0,nodes=[],mouse={x:-9999,y:-9999};
  function resize(){
    const r=canvas.getBoundingClientRect();
    W=canvas.width=r.width;H=canvas.height=r.height;
    canvas.style.width=W+'px';canvas.style.height=H+'px';
    nodes=[];
    const cols=Math.max(12,Math.round(W/100));
    const rows=Math.max(6,Math.round(H/100));
    for(let i=0;i<cols;i++)for(let j=0;j<rows;j++){
      const x=(i/(cols-1))*W,y=(j/(rows-1))*H;
      nodes.push({bx:x,by:y,x:x,y:y,r:Math.random()*1.2+.4});
    }
  }
  resize();window.addEventListener('resize',resize);
  section.addEventListener('mousemove',e=>{
    const r=canvas.getBoundingClientRect();
    mouse.x=e.clientX-r.left;mouse.y=e.clientY-r.top;
  },{passive:true});
  section.addEventListener('mouseleave',()=>{mouse.x=-9999;mouse.y=-9999;});
  function draw(){
    ctx.clearRect(0,0,W,H);
    const RADIUS=220;
    nodes.forEach(n=>{
      const dx=n.bx-mouse.x,dy=n.by-mouse.y;
      const d=Math.sqrt(dx*dx+dy*dy);
      const f=Math.max(0,RADIUS-d)/RADIUS;
      const ang=Math.atan2(dy,dx);
      const push=f*f*54;
      n.x+=(n.bx+Math.cos(ang)*push-n.x)*.1;
      n.y+=(n.by+Math.sin(ang)*push-n.y)*.1;
      ctx.beginPath();
      ctx.arc(n.x,n.y,n.r+f*2.4,0,Math.PI*2);
      ctx.fillStyle='rgba(255,145,0,'+(0.05+f*.5)+')';
      ctx.fill();
    });
    for(let i=0;i<nodes.length;i+=2){
      for(let j=i+1;j<nodes.length;j+=2){
        const a=nodes[i],b=nodes[j];
        const dx=a.x-b.x,dy=a.y-b.y;
        const d=Math.sqrt(dx*dx+dy*dy);
        if(d<78){
          const adx=a.bx-mouse.x,ady=a.by-mouse.y;
          const af=Math.max(0,RADIUS-Math.sqrt(adx*adx+ady*ady))/RADIUS;
          ctx.beginPath();
          ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
          ctx.strokeStyle='rgba(255,145,0,'+(1-d/78)*(.022+af*.13)+')';
          ctx.lineWidth=.55;ctx.stroke();
        }
      }
    }
    nodes.forEach(n=>{
      const dx=n.x-mouse.x,dy=n.y-mouse.y;
      const d=Math.sqrt(dx*dx+dy*dy);
      if(d<130){
        ctx.beginPath();
        ctx.moveTo(mouse.x,mouse.y);ctx.lineTo(n.x,n.y);
        ctx.strokeStyle='rgba(255,145,0,'+(1-d/130)*.4+')';
        ctx.lineWidth=.7;ctx.stroke();
      }
    });
    requestAnimationFrame(draw);
  }
  draw();
}

// Logo marquee — two rows scrolling opposite directions; slow on hover via Web Animations API
function initLogoMarquees(){
  if(window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches)return;
  document.querySelectorAll('.logo-track').forEach(track=>{
    const dir=track.dataset.direction==='right'?'right':'left';
    const from=dir==='left'?'0%':'-50%';
    const to=dir==='left'?'-50%':'0%';
    const anim=track.animate(
      [{transform:`translate3d(${from},0,0)`},{transform:`translate3d(${to},0,0)`}],
      {duration:60000,iterations:Infinity,easing:'linear'}
    );
    const marquee=track.parentElement;
    marquee.addEventListener('mouseenter',()=>{anim.updatePlaybackRate?anim.updatePlaybackRate(0.25):anim.playbackRate=0.25;});
    marquee.addEventListener('mouseleave',()=>{anim.updatePlaybackRate?anim.updatePlaybackRate(1):anim.playbackRate=1;});
  });
}

// Live Results strip — four live counters between the hero and Solutions
function initHeroStats(){
  const itemsEl=document.getElementById('hstat-items');
  const upEl=document.getElementById('hstat-uptime');
  const trEl=document.getElementById('hstat-training');
  const injEl=document.getElementById('hstat-injuries');
  if(!itemsEl&&!upEl&&!trEl&&!injEl)return;

  const fmt=n=>n.toLocaleString('en-US');

  // Current time as parts in America/Chicago — shared by the weekly-reset stats
  function getCentralParts(){
    const parts=new Intl.DateTimeFormat('en-US',{
      timeZone:'America/Chicago',
      year:'numeric',month:'numeric',day:'numeric',
      hour:'numeric',minute:'numeric',second:'numeric',
      weekday:'short',hour12:false
    }).formatToParts(new Date());
    const p={};parts.forEach(x=>p[x.type]=x.value);
    return p;
  }
  // Hours elapsed since the most recent Monday 5:00 AM Central
  function hoursSinceMonday5Central(){
    const p=getCentralParts();
    const dow={Sun:0,Mon:1,Tue:2,Wed:3,Thu:4,Fri:5,Sat:6}[p.weekday];
    let h=parseInt(p.hour,10);if(h===24)h=0;
    const m=parseInt(p.minute,10),s=parseInt(p.second,10);
    const hod=h+m/60+s/3600;
    let hoursSinceMon5;
    if(dow===1){
      hoursSinceMon5=hod<5?(7*24)+hod-5:hod-5;
    }else{
      const daysSinceMon=(dow+6)%7;
      hoursSinceMon5=daysSinceMon*24+hod-5;
      if(hoursSinceMon5<0)hoursSinceMon5+=7*24;
    }
    return hoursSinceMon5;
  }

  // 1) Items produced this week — starts at 1,157 every Monday 5AM Central, +63/second
  function itemsThisWeek(){
    return Math.floor(1157+hoursSinceMonday5Central()*3600*63);
  }

  // 2) Uptime — base 98.241%, last digits fluctuate within ±10 (98.231–98.251)
  function uptimeStr(){
    const v=98241+(Math.floor(Math.random()*21)-10);
    return (v/1000).toFixed(3);
  }

  // 3) Training hours — accumulates from a fixed reference so it always grows between visits
  const TRAINING_BASE=645520;
  const TRAINING_BASE_AT=Date.UTC(2026,4,12,0,0,0); // 2026-05-12T00:00:00Z
  const TRAINING_RATE_PER_SEC=0.42; // ~1,512/hour
  function trainingHours(){
    const elapsedSec=(Date.now()-TRAINING_BASE_AT)/1000;
    return Math.floor(TRAINING_BASE+Math.max(0,elapsedSec)*TRAINING_RATE_PER_SEC);
  }

  // 4) Reportable injuries prevented — starts at 8 every Monday 5AM Central, +3 every 77 minutes
  function injuriesPrevented(){
    const minutes=hoursSinceMonday5Central()*60;
    return 8+Math.floor(minutes/77)*3;
  }

  function tickFast(){
    if(itemsEl)itemsEl.textContent=fmt(itemsThisWeek());
    if(trEl)trEl.textContent=fmt(trainingHours());
    if(injEl)injEl.textContent=fmt(injuriesPrevented());
  }
  function tickUptime(){
    if(upEl)upEl.innerHTML=uptimeStr()+'<span class="rs-pct">%</span>';
  }

  tickFast();tickUptime();
  setInterval(tickFast,1000);
  setInterval(tickUptime,2500);
}

function initAll(){initCounters();initNavBottom();initHomeSections();initLogoMarquees();initHomeMagic();initHeroStats();}
if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded',initAll);
}else{
  initAll();
}
</script>
</Layout>
