---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Formic — Full Service Automation for Manufacturers"
  description="Formic delivers Robotics as a Service to mid-market CPG manufacturers. No CapEx. No Risk. No Problems. Industrial palletizing, case packing, and more."
  ogTitle="Formic — Full Service Automation"
  ogDescription="No CapEx. No Risk. No Problems. Robotics as a Service for mid-market manufacturers."
>
  <link rel="canonical" href="https://formic.co" slot="head" />
  <style is:global slot="head">
/* HERO video */
.video-hero{position:relative;height:100vh;min-height:680px;overflow:hidden;display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;padding:0 80px 96px}
.video-hero video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
.video-hero .vid-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(to top,rgba(9,21,23,.95) 0%,rgba(9,21,23,.55) 45%,rgba(9,21,23,.4) 100%),radial-gradient(ellipse at center,rgba(9,21,23,0) 30%,rgba(9,21,23,.75) 100%)}
.video-hero .hero-content{position:relative;z-index:2;max-width:900px}

/* AI vision overlay */
.ai-overlay{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.ai-overlay::before{content:"";position:absolute;inset:0;background:repeating-linear-gradient(to bottom,rgba(0,0,0,.18) 0,rgba(0,0,0,.18) 1px,transparent 1px,transparent 3px);opacity:.55;pointer-events:none}
.ai-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,145,0,.14) 1px,transparent 1px),linear-gradient(90deg,rgba(255,145,0,.14) 1px,transparent 1px);background-size:64px 64px;-webkit-mask-image:radial-gradient(ellipse at center,rgba(0,0,0,.95) 30%,transparent 82%);mask-image:radial-gradient(ellipse at center,rgba(0,0,0,.95) 30%,transparent 82%)}
.ai-scan{position:absolute;left:0;right:0;top:0;height:220px;background:linear-gradient(to bottom,transparent 0%,rgba(255,145,0,.08) 30%,rgba(255,145,0,.45) 50%,rgba(255,145,0,.08) 70%,transparent 100%);box-shadow:0 0 40px rgba(255,145,0,.15);animation:ai-scan 7s linear infinite}
@keyframes ai-scan{0%{transform:translateY(-220px)}100%{transform:translateY(100vh)}}
.ai-corner{position:absolute;width:46px;height:46px;fill:none;stroke:rgba(255,145,0,.95);stroke-width:2;filter:drop-shadow(0 0 6px rgba(255,145,0,.35))}
.ai-corner.tl{top:24px;left:24px}.ai-corner.tr{top:24px;right:24px}.ai-corner.bl{bottom:24px;left:24px}.ai-corner.br{bottom:24px;right:24px}
.ai-box{position:absolute;border:1.5px solid rgba(255,145,0,.9);background:rgba(255,145,0,.06);box-shadow:0 0 24px rgba(255,145,0,.18),inset 0 0 40px rgba(9,21,23,.35);animation:ai-pulse 3.2s ease-in-out infinite}
.ai-box::before,.ai-box::after{content:"";position:absolute;width:12px;height:12px;border:2px solid rgba(255,145,0,1)}
.ai-box::before{top:-2px;left:-2px;border-right:none;border-bottom:none}
.ai-box::after{bottom:-2px;right:-2px;border-left:none;border-top:none}
.ai-box.b1{top:26%;left:18%;width:22%;height:30%}
.ai-box.b2{top:42%;right:14%;width:18%;height:22%;animation-delay:1.6s}
.ai-box .ai-lbl{position:absolute;top:-24px;left:-2px;font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--white);background:rgba(255,145,0,.95);padding:4px 8px;white-space:nowrap;box-shadow:0 0 12px rgba(255,145,0,.4)}
@keyframes ai-pulse{0%,100%{opacity:.75;border-color:rgba(255,145,0,.7);box-shadow:0 0 20px rgba(255,145,0,.15),inset 0 0 40px rgba(9,21,23,.35)}50%{opacity:1;border-color:rgba(255,145,0,1);box-shadow:0 0 40px rgba(255,145,0,.35),inset 0 0 40px rgba(9,21,23,.4)}}
.ai-hud{position:absolute;display:flex;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:rgba(240,245,241,.85);text-shadow:0 0 8px rgba(9,21,23,.9)}
.ai-hud.tl-hud{top:76px;left:80px;flex-direction:row;align-items:center;gap:10px}
.ai-hud.tr-hud{top:76px;right:80px;flex-direction:column;align-items:flex-end;gap:4px;text-align:right}
.ai-hud.tr-hud span{color:rgba(255,145,0,.9);text-shadow:0 0 8px rgba(255,145,0,.25),0 0 8px rgba(9,21,23,.9)}
.ai-dot{width:9px;height:9px;border-radius:50%;background:var(--orange);box-shadow:0 0 14px rgba(255,145,0,1),0 0 4px rgba(255,145,0,1);animation:ai-blink 1.3s ease-in-out infinite}
@keyframes ai-blink{0%,100%{opacity:1}50%{opacity:.3}}
.ai-crosshair{position:absolute;top:50%;left:50%;width:28px;height:28px;transform:translate(-50%,-50%);opacity:.75;filter:drop-shadow(0 0 6px rgba(255,145,0,.4))}
.ai-crosshair::before,.ai-crosshair::after{content:"";position:absolute;background:rgba(255,145,0,.95)}
.ai-crosshair::before{top:50%;left:0;right:0;height:1px;transform:translateY(-50%)}
.ai-crosshair::after{left:50%;top:0;bottom:0;width:1px;transform:translateX(-50%)}
.video-mute{position:absolute;bottom:36px;right:80px;z-index:3;background:rgba(9,21,23,.6);border:1px solid rgba(240,245,241,.18);color:rgba(240,245,241,.6);font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;padding:8px 14px;cursor:none;transition:color .2s,border-color .2s}
.video-mute:hover{color:var(--white);border-color:rgba(240,245,241,.45)}

/* HOME SECTION pattern: header + tab strip + horizontal scroll-snap track */
.home-section{position:relative;overflow:hidden}
.home-section.dark{background:var(--black);color:var(--white)}
.home-section.dgrey{background:var(--dgrey);color:var(--white)}
.home-section.lgrey{background:var(--lgrey)}
.home-section.white{background:var(--white)}
.hsection-head{padding:72px 80px 24px;max-width:1280px;margin:0 auto}
.hsection-head .slabel{margin-bottom:16px}
.hsection-head h2{font-family:var(--sans);font-weight:600;font-size:clamp(44px,5.4vw,80px);line-height:.96;letter-spacing:-.025em;margin-bottom:20px}
.home-section.dark .hsection-head h2,.home-section.dgrey .hsection-head h2{color:var(--white)}
.hsection-head h2 em{color:var(--orange);font-style:normal}
.hsection-head .blurb{font-size:17px;font-weight:300;line-height:1.7;max-width:580px;color:var(--mgrey)}
.home-section.dark .hsection-head .blurb,.home-section.dgrey .hsection-head .blurb{color:rgba(240,245,241,.6)}
.hsection-head .more-link{display:inline-flex;align-items:center;gap:14px;margin-top:36px;font-family:var(--sans);font-size:clamp(20px,2vw,28px);font-weight:500;letter-spacing:-.01em;color:var(--orange);text-decoration:none;padding:18px 32px;border:2px solid var(--orange);border-radius:0;background:transparent;transition:background .25s,color .25s,gap .25s}
.hsection-head .more-link::after{content:"→";font-family:var(--sans);font-size:1em;display:inline-block;transition:transform .25s}
.hsection-head .more-link:hover{background:var(--orange);color:var(--black);gap:18px}
.hsection-head .more-link:hover::after{transform:translateX(4px)}
.home-section.dark .hsection-head .more-link:hover,.home-section.dgrey .hsection-head .more-link:hover{color:var(--white);background:var(--orange)}

/* tab strip — visually distinct from content panels */
.hsection-tabs{display:flex;gap:0;max-width:1280px;margin:0 auto;padding:8px 80px 28px;flex-wrap:wrap}
.htab{flex:1 1 160px;background:transparent;padding:18px 20px;cursor:none;text-decoration:none;border:none;border-top:1px solid rgba(0,0,0,.1);border-bottom:2px solid transparent;text-align:left;font:inherit;color:inherit;transition:border-color .25s,background .25s;display:flex;flex-direction:column;gap:6px;position:relative}
.home-section.dark .htab,.home-section.dgrey .htab{border-top-color:rgba(240,245,241,.1)}
.htab:hover{background:rgba(255,145,0,.04);border-bottom-color:rgba(255,145,0,.45)}
.htab.active{border-bottom-color:rgba(255,145,0,.28);background:rgba(255,145,0,.06)}
/* auto-rotate progress bar — fills the active tab over the cycle, pauses on hover */
.htab::after{content:"";position:absolute;left:0;right:auto;bottom:-2px;height:2px;width:var(--htab-progress,0%);background:var(--orange);box-shadow:0 0 8px rgba(255,145,0,.5);pointer-events:none;opacity:0;transition:opacity .2s ease}
.htab.active::after{opacity:1}
.htab .htab-num{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--mgrey);text-transform:uppercase;transition:color .2s}
.home-section.dark .htab .htab-num,.home-section.dgrey .htab .htab-num{color:rgba(240,245,241,.4)}
.htab.active .htab-num,.htab:hover .htab-num{color:var(--orange)}
.htab h3{font-family:var(--sans);font-size:16px;font-weight:500;letter-spacing:-.01em;line-height:1.25;margin:0}
.home-section.dark .htab h3,.home-section.dgrey .htab h3{color:var(--white)}
.htab .htab-arrow{position:absolute;top:18px;right:20px;font-family:var(--mono);font-size:11px;color:var(--orange);opacity:0;transition:opacity .2s,transform .2s}
.htab:hover .htab-arrow,.htab.active .htab-arrow{opacity:1;transform:translateX(2px)}

/* horizontal track */
.hsection-track{position:relative;display:flex;flex-wrap:nowrap;overflow-x:auto;overflow-y:hidden;scroll-snap-type:x mandatory;scroll-behavior:smooth;scrollbar-width:none;-ms-overflow-style:none;width:100vw;max-width:100%}
.hsection-track::-webkit-scrollbar{display:none}
.hpanel{flex:0 0 100vw;width:100vw;min-width:100vw;scroll-snap-align:start;display:grid;grid-template-columns:380px 1fr;column-gap:56px;align-items:center;min-height:380px;background:inherit;position:relative;padding:32px 80px;max-width:1280px;margin:0 auto}
.hpanel.text-only{grid-template-columns:1fr;padding:40px 80px}
.hpanel-img{position:relative;overflow:hidden;background:var(--black);width:380px;height:380px;aspect-ratio:1/1;flex-shrink:0}
.hpanel-img img,.hpanel-img video{width:100%;height:100%;object-fit:cover;display:block;aspect-ratio:1/1}
.hpanel-img .img-cap{position:absolute;bottom:18px;left:24px;font-family:var(--mono);font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:rgba(240,245,241,.7)}
.hpanel-text{padding:0 0 56px;display:flex;flex-direction:column;justify-content:center;position:relative}
.hpanel-explore{position:absolute;bottom:28px;right:48px;font-family:var(--mono);font-size:13px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);text-decoration:none;display:inline-flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,145,0,.4);transition:gap .25s ease,border-color .25s ease;z-index:3}

/* Customer quote gallery panel */
.hpanel.quotes-panel{display:flex;align-items:center;justify-content:center;padding:64px 80px;min-height:480px}
.stories-quotes{padding:24px 80px 80px;max-width:1280px;margin:0 auto;display:flex;justify-content:center}
.quote-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:48px 64px;width:100%;max-width:1280px}
.quote-item{display:flex;flex-direction:column;gap:18px;border-left:2px solid var(--orange);padding-left:28px;margin:0}
.quote-text{font-family:var(--sans);font-size:clamp(22px,2.4vw,32px);font-weight:500;line-height:1.25;letter-spacing:-.01em;color:var(--black);margin:0}
.home-section.dark .quote-text,.home-section.dgrey .quote-text{color:var(--white)}
.quote-attr{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--mgrey);font-style:normal}
.home-section.dark .quote-attr,.home-section.dgrey .quote-attr{color:rgba(240,245,241,.5)}
@media(max-width:900px){
  .hpanel.quotes-panel{padding:40px 24px}
  .stories-quotes{padding:16px 24px 56px}
  .quote-gallery{grid-template-columns:1fr;gap:32px}
  .quote-text{font-size:20px}
}
.hpanel-explore::after{content:"→";font-family:var(--sans);font-weight:500;font-size:1em;display:inline-block;transition:transform .25s ease}
.hpanel-explore:hover{gap:16px;border-color:var(--orange)}
.hpanel-explore:hover::after{transform:translateX(4px)}
.home-section.dark .hpanel-text,.home-section.dgrey .hpanel-text{color:var(--white)}
.hpanel-text .ptag{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);margin-bottom:14px}
.hpanel-text h3{font-family:var(--sans);font-size:clamp(32px,3.4vw,52px);font-weight:500;letter-spacing:-.02em;line-height:1.05;margin-bottom:20px;color:var(--black)}
.home-section.dark .hpanel-text h3,.home-section.dgrey .hpanel-text h3{color:var(--white)}
.hpanel-text p{font-size:16px;font-weight:300;line-height:1.75;color:var(--mgrey);margin-bottom:22px}
.home-section.dark .hpanel-text p,.home-section.dgrey .hpanel-text p{color:rgba(240,245,241,.6)}
.hpanel-text .feat-list{list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px}
.hpanel-text .feat-list li{font-size:14px;font-weight:300;line-height:1.55;padding-left:14px;position:relative}
.hpanel-text .feat-list li::before{content:"";position:absolute;left:0;top:8px;width:5px;height:5px;border-radius:50%;background:var(--orange)}
.hpanel-text .larr{align-self:flex-start}

/* Stats row inside Results section */
.statsrow{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(240,245,241,.1);max-width:1280px;margin:0 auto 0;width:100%}
.stcell{background:var(--dgrey);padding:64px 28px 56px;text-align:left;display:flex;flex-direction:column;align-items:flex-start;gap:14px;transition:background .25s ease}
.stcell:hover{background:#3d4946}
.stnum{font-family:var(--sans);font-size:clamp(60px,5.4vw,86px);font-weight:500;color:var(--white);line-height:.92;display:block;letter-spacing:-.03em}
.stlbl{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,245,241,.55)}

/* Learn More — 4-card row */
.lm-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(240,245,241,.06);max-width:100%}
.lm-card{position:relative;background:#0d181a;padding:48px 32px 36px;display:flex;flex-direction:column;gap:14px;text-decoration:none;color:var(--white);transition:background .3s ease,padding-left .3s ease;cursor:none;min-height:340px}
.lm-card:hover{background:#14272b}
.lm-card-num{font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,145,0,.85)}
.lm-card h3{font-family:var(--sans);font-weight:600;font-size:clamp(22px,1.8vw,28px);letter-spacing:-.015em;line-height:1.1;color:var(--white);margin:0}
.lm-card p{font-family:var(--sans);font-size:14px;font-weight:300;line-height:1.6;color:rgba(240,245,241,.55);margin:0}
.lm-card-arrow{font-family:var(--sans);font-size:24px;color:var(--orange);margin-top:auto;display:inline-block;transition:transform .3s ease}
.lm-card:hover .lm-card-arrow{transform:translateX(6px)}
@media (max-width:1180px){.lm-grid{grid-template-columns:repeat(2,1fr)}}
@media (max-width:640px){.lm-grid{grid-template-columns:1fr}.lm-card{min-height:260px;padding:32px 24px 28px}}

/* Magic section — cursor-interactive canvas + spotlight (scoped) */
.home-magic{position:relative;overflow:hidden}
.home-magic #home-mg-canvas{position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none}
.home-magic .home-mg-spot{position:absolute;top:0;left:0;width:680px;height:680px;border-radius:50%;background:radial-gradient(circle,rgba(255,145,0,.10) 0%,rgba(255,145,0,.04) 35%,transparent 70%);transform:translate3d(var(--home-mx,50%),var(--home-my,50%),0) translate(-50%,-50%);pointer-events:none;z-index:1;mix-blend-mode:screen;opacity:0;transition:opacity .35s ease}
.home-magic.is-cursor-in .home-mg-spot{opacity:1}
.home-magic-inner{position:relative;z-index:2}

/* Solutions tile grid (Anduril-style) */
.sol-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(240,245,241,.06)}
.sol-grid-4{grid-template-columns:repeat(4,1fr)}
.sol-tile{position:relative;aspect-ratio:1/1;overflow:hidden;display:block;text-decoration:none;color:var(--white);background:var(--dgrey);transition:transform .35s cubic-bezier(.2,.6,.2,1)}
.sol-tile:hover{transform:translateY(-4px)}
.sol-grid-4 .sol-tile{aspect-ratio:1/1.05}
.sol-tile-feat{grid-column:span 2;aspect-ratio:2/1}
.sol-tile-wide{grid-column:span 2}
.sol-grid-4 .sol-tile-wide{aspect-ratio:2/1.05}
.sol-tile img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .8s cubic-bezier(.2,.6,.2,1),filter .4s ease;filter:brightness(.62) saturate(.88)}
.sol-tile:hover img{transform:scale(1.06);filter:brightness(.92) saturate(1)}
/* Static-poster + animated-GIF swap: static visible by default, GIF fades in on hover */
.sol-tile .sol-anim{opacity:0;transition:opacity .25s ease,transform .8s cubic-bezier(.2,.6,.2,1),filter .4s ease}
.sol-tile:hover .sol-anim{opacity:1}
.sol-tile:hover .sol-static{opacity:0}
.sol-tile .sol-static{transition:opacity .25s ease,transform .8s cubic-bezier(.2,.6,.2,1),filter .4s ease}
.sol-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(9,21,23,.92) 100%);z-index:1;pointer-events:none}
.sol-content{position:absolute;left:28px;bottom:24px;right:28px;z-index:2}
.sol-name{font-family:var(--sans);font-weight:600;font-size:clamp(20px,1.9vw,28px);line-height:1.05;letter-spacing:-.015em;color:var(--white);margin-bottom:6px}
.sol-tag{font-family:var(--sans);font-size:13px;font-weight:300;color:rgba(240,245,241,.78);letter-spacing:.005em;line-height:1.4}
/* Hover-reveal overlay — slides a fuller description over the tile on hover */
.sol-hover-overlay{position:absolute;inset:0;z-index:3;background:linear-gradient(180deg,rgba(10,9,8,.55) 0%,rgba(10,9,8,.95) 55%);padding:32px 28px 26px;display:flex;flex-direction:column;justify-content:flex-end;opacity:0;transition:opacity .35s ease;pointer-events:none}
.sol-tile:hover .sol-hover-overlay,.sol-tile:focus-visible .sol-hover-overlay{opacity:1}
.sol-hover-name{font-family:var(--sans);font-weight:600;font-size:clamp(20px,1.9vw,28px);line-height:1.05;letter-spacing:-.015em;color:var(--white);margin-bottom:12px}
.sol-hover-text{font-family:var(--sans);font-size:13px;font-weight:300;line-height:1.55;color:rgba(240,236,228,.88)}
.sol-fpo{position:absolute;top:14px;right:14px;z-index:3;font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.7);background:rgba(0,0,0,.45);backdrop-filter:blur(8px);padding:4px 9px;border:1px solid rgba(255,255,255,.18)}
/* Coming Soon tile — orange-tinted, no image, CTA-style */
.sol-tile-soon{background:linear-gradient(135deg,rgba(255,145,0,.14) 0%,rgba(255,145,0,.04) 60%,rgba(9,21,23,.85) 100%);display:flex;align-items:flex-end;padding:32px 36px;cursor:none;overflow:hidden}
.sol-tile-soon::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(255,145,0,.2) 0%,transparent 55%);opacity:.7;pointer-events:none}
.sol-tile-soon::after{content:"+";position:absolute;top:20px;right:24px;font-family:var(--sans);font-weight:300;font-size:64px;line-height:1;color:rgba(255,145,0,.5);transition:transform .35s ease,color .35s ease}
.sol-tile-soon:hover::after{transform:rotate(45deg);color:var(--orange)}
.sol-soon-content{position:relative;z-index:2;display:flex;flex-direction:column;gap:10px;max-width:560px}
.sol-soon-tag{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--orange)}
.sol-soon-name{font-family:var(--sans);font-weight:600;font-size:clamp(28px,2.6vw,40px);letter-spacing:-.02em;line-height:1;color:var(--white)}
.sol-soon-desc{font-family:var(--sans);font-size:14px;font-weight:300;line-height:1.55;color:rgba(240,245,241,.72)}
.sol-soon-cta{margin-top:8px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange);border-bottom:1px solid var(--orange);padding-bottom:3px;align-self:flex-start;transition:gap .2s,opacity .2s}
.sol-tile-soon:hover .sol-soon-cta{opacity:.85}
@media (max-width:1180px){.sol-grid-4{grid-template-columns:repeat(3,1fr)}.sol-grid-4 .sol-tile{aspect-ratio:1/1}}
@media (max-width:1024px){.sol-grid{grid-template-columns:repeat(2,1fr)}.sol-tile-feat,.sol-tile-wide{grid-column:span 2;aspect-ratio:2.2/1}.sol-grid-4{grid-template-columns:repeat(2,1fr)}}
@media (max-width:640px){.sol-grid{grid-template-columns:1fr}.sol-tile,.sol-tile-feat,.sol-tile-wide{grid-column:auto;aspect-ratio:16/10}.sol-grid-4{grid-template-columns:1fr}.sol-grid-4 .sol-tile{aspect-ratio:16/10}.sol-tile-soon{padding:28px 24px}}

/* Logo marquee — used inside Results section */
.logo-rows{display:flex;flex-direction:column;gap:18px;padding:0 0 28px}
.logo-rows-inset{padding:8px 0 36px}
