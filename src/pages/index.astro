  <script is:inline slot="scripts">
function toggleMute(){
  const vid=document.getElementById('heroVid');
  const btn=document.getElementById('muteBtn');
  if(!vid||!btn)return;
  vid.muted=!vid.muted;
  btn.textContent=vid.muted?'Unmute':'Mute';
}

// Stat counter — counts up from 0 on hover
function initCounters(){
  const els=document.querySelectorAll('.stnum[data-count-to]');
  if(!els.length)return;
  const ease=t=>1-Math.pow(1-t,3);
  function run(el){
    const target=parseFloat(el.dataset.countTo)||0;
    const prefix=el.dataset.prefix||'';
    const suffix=el.dataset.suffix||'';
    const dur=1200,start=performance.now();
    if(el._raf)cancelAnimationFrame(el._raf);
    function step(now){
      const t=Math.min(1,(now-start)/dur);
      const v=Math.round(target*ease(t));
      el.textContent=prefix+v+suffix;
      if(t<1)el._raf=requestAnimationFrame(step);
    }
    el._raf=requestAnimationFrame(step);
  }
  els.forEach(el=>{
    const cell=el.closest('.stcell')||el;
    cell.style.cursor='none';
    cell.addEventListener('mouseenter',()=>run(el));
  });
}

// Nav goes light when CTA section is in view
function initNavBottom(){
  const nav=document.getElementById('nav');
  const trigger=document.getElementById('cta');
  if(!nav||!trigger)return;
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>nav.classList.toggle('nav-bottom',e.isIntersecting));
  },{threshold:.15});
  obs.observe(trigger);
}

// Generic horizontal section: each .home-section with a tab strip + track
function initHomeSections(){
  document.querySelectorAll('.home-section').forEach(section=>{
    const track=section.querySelector('.hsection-track');
    const tabs=Array.from(section.querySelectorAll('.htab'));
    if(!track||!tabs.length)return;
    const panels=tabs.map(t=>section.querySelector(t.dataset.target)).filter(Boolean);
    function setActive(panel){
      const i=panels.indexOf(panel);
      if(i<0)return;
      tabs.forEach(x=>x.classList.remove('active'));
      tabs[i].classList.add('active');
    }
    function scrollToPanel(panel){
      if(!panel)return;
      const trackRect=track.getBoundingClientRect();
      const panelRect=panel.getBoundingClientRect();
      const left=track.scrollLeft+(panelRect.left-trackRect.left);
      track.scrollTo({left,behavior:'smooth'});
    }
    tabs.forEach((t,i)=>{
      t.addEventListener('click',function(e){
        e.preventDefault();
        scrollToPanel(panels[i]);
        setActive(panels[i]);
      });
    });
    const obs=new IntersectionObserver(entries=>{
      entries.forEach(e=>{if(e.isIntersecting)setActive(e.target);});
    },{root:track,threshold:.55});
    panels.forEach(p=>obs.observe(p));
  });
}

function initAll(){initCounters();initNavBottom();initHomeSections();}
if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded',initAll);
}else{
  initAll();
}
</script>
