---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Full Service Automation — Formic" description="Formic's Full Service Automation model covers everything — robots, software, maintenance, and support — for one monthly fee.">
  <style is:global slot="head">
.how-steps{counter-reset:step;display:flex;flex-direction:column;gap:1px;background:var(--lgrey)}
.step{background:var(--white);display:grid;grid-template-columns:80px 1fr 1fr;gap:0;align-items:start;padding:52px 48px;counter-increment:step;position:relative;transition:background .25s}
.step:hover{background:#e8ede9}
.step::before{content:counter(step,decimal-leading-zero);font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.12em;color:var(--lgrey);padding-top:4px}
.step h3{font-family:var(--sans);font-size:22px;font-weight:500;letter-spacing:-.01em;color:var(--black);margin-bottom:10px}
.step p{font-size:15px;font-weight:300;color:var(--mgrey);line-height:1.75}
.step-tag{display:inline-block;font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--orange);margin-bottom:10px}
.sla-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--lgrey)}
.sla-cell{background:var(--dgrey);padding:44px 32px;text-align:center}
.sla-big{font-family:var(--sans);font-size:52px;font-weight:500;color:var(--white);line-height:1;letter-spacing:-.02em;display:block;margin-bottom:8px}
.sla-cell p{font-size:13px;font-weight:300;color:rgba(240,245,241,.45);line-height:1.6}
.pricing-box{background:var(--black);padding:72px 64px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
.price-card{background:rgba(240,245,241,.04);border:1px solid rgba(240,245,241,.08);padding:36px;position:relative}
.price-card.featured{border-color:var(--orange)}
.price-badge{position:absolute;top:-12px;left:24px;background:var(--orange);color:var(--black);font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;padding:4px 10px}
.price-label{font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--mgrey);margin-bottom:12px}
.price-amount{font-family:var(--sans);font-size:42px;font-weight:500;color:var(--white);letter-spacing:-.02em;line-height:1;margin-bottom:6px}
.price-period{font-family:var(--mono);font-size:10px;color:var(--mgrey);letter-spacing:.08em}
.price-note{font-size:13px;font-weight:300;color:rgba(240,245,241,.35);margin-top:16px;line-height:1.6}
@media(max-width:900px){.step{grid-template-columns:40px 1fr;padding:32px 24px}.step p{display:none}.pricing-box{grid-template-columns:1fr;padding:40px 24px}.sla-grid{grid-template-columns:1fr}}
  </style>

<!-- HERO with full-bleed factory photo -->
<section class="page-hero">
  <div class="hero-bg-img" style="background-image:url('/Focus-7603.jpg')"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="mono-label">Full Service Automation</div>
    <h1 class="dtitle lg wh" style="margin-bottom:20px">Everything.<br><em>Included.</em></h1>
    <p class="btext wh" style="max-width:520px">One fixed monthly price covers the equipment, the service, and the technology. No CapEx. No surprise costs. No internal resources needed.</p>
    <div class="hero-btns">
      <a href="/company#demo" class="btn-hero solid">Get a Demo</a>
      <a href="#how" class="btn-hero outline">How It Works</a>
    </div>
  </div>
  <div class="scroll-hint"><div class="sline"></div><span>Scroll</span></div>
</section>

<!-- THREE PILLARS -->
<section class="bg-white">
  <div class="si rv">
    <div class="slabel">The Model</div>
    <h2 class="dtitle" style="margin-bottom:52px">Three pillars.<br><em>One contract.</em></h2>
    <div class="three-col">
      <div class="card-cell">
        <span class="card-num">01 —</span>
        <div class="card-lbl">Get the Job Done</div>
        <h3>Systems &amp; Equipment</h3>
        <p>Engineers scope, test, program, ship, and deploy the right robotic system for your production needs. Modular "Lego-block" architecture for consistent, repeatable performance.</p>
        <a href="/solutions" class="larr">View solutions →</a>
      </div>
      <div class="card-cell">
        <span class="card-num">02 —</span>
        <div class="card-lbl">Keep It Running</div>
        <h3>Service &amp; Support</h3>
        <p>24/7 bilingual tech support, Field Service Engineers, and contracted performance SLAs. Corrective and preventive maintenance 100% covered. Parts and training included.</p>
        <a href="#service" class="larr">Service details →</a>
      </div>
      <div class="card-cell">
        <span class="card-num">03 —</span>
        <div class="card-lbl">Optimize Performance</div>
        <h3>Technology &amp; Software</h3>
        <p>Real-time production data, continuous feature rollouts, and remote diagnostics that give your team better visibility than any legacy system ever offered.</p>
        <a href="/platform" class="larr">Explore platform →</a>
      </div>
    </div>
  </div>
</section>

<!-- FULLBLEED GIF STRIP -->
<div class="gif-strip rv">
  <div class="gif-cell">
    <img src="/Haviland_Products_-_Palletizing.gif" alt="Formic palletizer in continuous operation">
    <span class="gif-label">Industrial palletizing</span>
  </div>
  <div class="gif-cell">
    <img src="/CasepackerPromoVideo_NoText.gif" alt="Formic case packer running at speed">
    <span class="gif-label">Case packing</span>
  </div>
</div>

<!-- VIDEO SPLIT 1: ZzWbNn-EU_0 — Full Service / See it in action -->
<section class="bg-white rv" style="padding:0">
  <div class="video-split">
    <div class="yt-facade" data-ytid="ZzWbNn-EU_0" onclick="loadYT(this)">
      <img
        src="https://i.ytimg.com/vi/ZzWbNn-EU_0/maxresdefault.jpg"
        alt="Formic Full Service Automation — see it in action"
        loading="lazy"
        onerror="this.src='/Focus-7603.jpg'"
      >
      <div class="yt-play"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
      <span class="yt-label">Watch: Full Service Automation</span>
    </div>
    <div class="vs-text light">
      <div class="slabel">In Action</div>
      <h2 class="dk">See Full Service<br><em>Automation live</em></h2>
      <p class="vs-body dk">Watch how Formic scopes, deploys, and supports a complete end-of-line automation system — from first conversation to running production.</p>
      <a href="/company#demo" class="larr">Get a Demo →</a>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how" class="bg-lgrey">
  <div class="si rv" style="padding-bottom:0">
    <div class="slabel">How It Works</div>
    <h2 class="dtitle" style="margin-bottom:52px">From inquiry<br><em>to running</em></h2>
  </div>
  <div class="how-steps rv d1">
    <div class="step">
      <span></span>
      <div>
        <div class="step-tag">Week 1</div>
        <h3>Application Scoping</h3>
      </div>
      <p>Our engineers assess your production line, throughput requirements, product specs, and floor constraints. FormicFAST matches your application to a pre-engineered solution within days — not weeks of custom engineering.</p>
    </div>
    <div class="step">
      <span></span>
      <div>
        <div class="step-tag">Weeks 2–4</div>
        <h3>System Configuration &amp; Testing</h3>
      </div>
      <p>Your system is built, programmed, and fully tested off-site before it ships. Pre-configured for your specific products, packaging formats, and throughput targets. What arrives on your floor is ready to run.</p>
    </div>
    <div class="step">
      <span></span>
      <div>
        <div class="step-tag">Weeks 4–6</div>
        <h3>Installation &amp; Commissioning</h3>
      </div>
      <p>Field Service Engineers handle the full install. Operator training — bilingual — is included. We don't leave until your team is confident and your system is hitting contracted performance rates.</p>
    </div>
    <div class="step">
      <span></span>
      <div>
        <div class="step-tag">Ongoing</div>
        <h3>24/7 Support &amp; Optimization</h3>
      </div>
      <p>Remote monitoring, proactive diagnostics, preventive maintenance visits, immediate corrective response — all included. Your system improves through continuous software updates. Performance SLAs are in your contract.</p>
    </div>
  </div>
</section>

<!-- SERVICE DETAIL with image -->
<section id="service" class="bg-white">
  <div class="product-detail rv" style="display:grid;grid-template-columns:1fr 1fr;gap:0;background:var(--lgrey)">
    <div class="pd-text" style="background:var(--white);padding:72px 64px">
      <div class="slabel">Service &amp; Support</div>
      <h2 style="font-family:var(--sans);font-size:clamp(36px,3.5vw,52px);font-weight:500;letter-spacing:-.02em;color:var(--black);line-height:1.05;margin-bottom:20px">We own<br>the uptime.</h2>
      <p class="btext" style="margin-bottom:32px">Every Formic contract includes contracted performance SLAs. If your system doesn't hit the numbers we promised, we fix it — on our dime, not yours.</p>
      <ul class="feat-list">
        <li>24/7 bilingual tech support — phone, chat, and remote diagnostic access</li>
        <li>Field Service Engineers for on-site corrective response</li>
        <li>100% preventive and corrective maintenance coverage</li>
        <li>Spare parts inventory managed and stocked by Formic</li>
        <li>Operator and maintenance training included at install and ongoing</li>
        <li>System upgrades and feature enhancements delivered automatically</li>
      </ul>
    </div>
    <div class="pd-img">
      <img src="/R52_5359.jpg" alt="Formic FSE engineer at laptop during system installation" loading="lazy" style="min-height:520px;width:100%;object-fit:cover">
    </div>
  </div>
</section>

<!-- SLA STATS -->
<div class="sla-grid rv">
  <div class="sla-cell"><span class="sla-big">24/7</span><div class="stat-lbl" style="color:var(--mgrey)">Technical Support</div><p>Phone, remote, and on-site — around the clock, every day.</p></div>
  <div class="sla-cell"><span class="sla-big">100%</span><div class="stat-lbl" style="color:var(--mgrey)">Maintenance Covered</div><p>All corrective and preventive maintenance fully included in your contract.</p></div>
  <div class="sla-cell"><span class="sla-big">SLA</span><div class="stat-lbl" style="color:var(--mgrey)">Contracted Uptime</div><p>Performance guarantees written into your agreement. We own the risk.</p></div>
</div>

<!-- PRICING -->
<section class="bg-black" id="pricing">
  <div class="pricing-box rv">
    <div>
      <div class="slabel" style="color:var(--orange)">Pricing</div>
      <h2 class="dtitle wh" style="margin-bottom:20px">One fixed<br><em>monthly price</em></h2>
      <p class="btext wh" style="margin-bottom:28px">No CapEx. No hidden costs. Equipment, service, software, and support — all in one predictable monthly fee. Cancel anytime on monthly agreements.</p>
      <p style="font-size:13px;font-weight:300;color:rgba(240,245,241,.3);line-height:1.7">Pricing varies by system type and configuration. The example below is for an Automate NOW Industrial Palletizer.</p>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px">
      <div class="price-card">
        <div class="price-label">Monthly Agreement</div>
        <div class="price-amount">,975</div>
        <div class="price-period">/month · cancel anytime</div>
        <p class="price-note">Full equipment, service, parts, software, and support. No long-term lock-in.</p>
      </div>
      <div class="price-card featured">
        <div class="price-badge">Most popular</div>
        <div class="price-label">Annual Agreement</div>
        <div class="price-amount">from ,975</div>
        <div class="price-period">/month · 12-month term</div>
        <p class="price-note">Best value. Same full coverage with preferred pricing. Swap systems as your needs evolve.</p>
      </div>
      <a href="/company#demo" class="btn-orange" style="text-align:center;display:block;padding:14px">Get a Custom Quote</a>
    </div>
  </div>
</section>

<!-- FULLBLEED IMAGE -->
<div class="fullbleed-wrap rv">
  <img src="/R52_8950-2.jpg" class="fullbleed" alt="Formic KUKA robotic arm against American flag — made in the USA" loading="lazy">
  <div class="fullbleed-caption">Driving U.S. manufacturing forward</div>
</div>

<!-- CTA -->
<div class="cta-band rv">
  <h2>No CapEx.<br>No Risk.</h2>
  <div class="cta-band-btns">
    <a href="/company#demo" class="btn-dark">Get a Demo</a>
    <a href="/solutions" class="btn-wh-border">See Solutions</a>
  </div>
</div>

  <script is:inline slot="scripts">
function loadYT(el){
  const id=el.dataset.ytid;
  const w=document.createElement('div');
  w.className='vs-embed fill';
  w.innerHTML=`<iframe src="https://www.youtube.com/embed/${id}?autoplay=1&rel=0&modestbranding=1" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy" title="Formic video"></iframe>`;
  el.replaceWith(w);
}
  </script>
</Layout>
