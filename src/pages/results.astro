---
import Layout from '../layouts/Layout.astro';
import { getResultsPage } from '../lib/sanity';

let resultsData: any = null;
try { resultsData = await getResultsPage(); } catch(e) {}
---

<Layout title="Results — Formic" description="Real outcomes from real manufacturers: 20% OpEx reduction, $0 CapEx, 2-week deployment.">
  <style is:global slot="head">
.results-hero{position:relative;height:75vh;min-height:540px;overflow:hidden;display:flex;align-items:flex-end;padding:0 80px 88px}
.rh-bg{position:absolute;inset:0;background:url('/MiMFG_Photos-24.jpg') center/cover;filter:brightness(.25) saturate(.5)}
.rh-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(9,21,23,.9) 0%,transparent 60%)}
.big-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--orange)}
.big-stat{background:var(--black);padding:56px 32px;text-align:center;transition:background .25s}
.big-stat:hover{background:var(--dgrey)}
.bsn{font-family:var(--sans);font-size:72px;font-weight:500;color:var(--orange);line-height:1;display:block;margin-bottom:8px;letter-spacing:-.03em}
.bsl{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(240,245,241,.4)}
.bsd{font-size:13px;font-weight:300;color:rgba(240,245,241,.3);line-height:1.5;margin-top:8px}
.outcome-section{display:grid;grid-template-columns:1fr 1fr;gap:0;background:var(--lgrey);margin-bottom:2px}
.os-text{padding:72px 64px;background:var(--white)}
.os-img{overflow:hidden;min-height:460px;position:relative}
.os-img img,.os-img video{width:100%;height:100%;object-fit:cover;display:block}
.os-text h2{font-family:var(--sans);font-size:clamp(34px,3.5vw,50px);font-weight:500;letter-spacing:-.02em;color:var(--black);line-height:1.05;margin-bottom:16px}
.os-text .btext{margin-bottom:24px}
.evidence-list{list-style:none;margin-bottom:28px}
.evidence-list li{font-size:14px;font-weight:300;color:var(--dgrey);padding:10px 0;border-bottom:1px solid var(--lgrey);display:flex;align-items:baseline;gap:10px;line-height:1.5}
.evidence-list li::before{content:'';width:5px;height:5px;background:var(--orange);border-radius:50%;flex-shrink:0;margin-top:6px}
@media(max-width:900px){.results-hero{padding:0 24px 60px}.big-stats{grid-template-columns:1fr 1fr}.bsn{font-size:52px}.outcome-section{grid-template-columns:1fr}.os-text{padding:40px 24px}}
  </style>

<!-- HERO -->
<section class="results-hero">
  <div class="rh-bg"></div>
  <div class="rh-overlay"></div>
  <div style="position:relative;z-index:2;max-width:840px">
    <div class="mono-label">Results</div>
    <h1 class="dtitle lg wh" style="margin-bottom:20px">Measurable<br><em>impact</em></h1>
    <p class="btext wh" style="max-width:520px">Real outcomes from real production floors. Not projections — actual results from Formic customers across mid-market CPG manufacturing.</p>
  </div>
</section>

<!-- BIG STATS BAR -->
<div class="big-stats rv">
  {resultsData?.bigStats ? (
    resultsData.bigStats.map((stat: any) => (
      <div class="big-stat"><span class="bsn">{stat.value}</span><span class="bsl">{stat.label}</span>{stat.description && <p class="bsd">{stat.description}</p>}</div>
    ))
  ) : (
    <>
      <div class="big-stat"><span class="bsn">20%</span><span class="bsl">OpEx Reduction</span><p class="bsd">Land O'Frost cut operating costs 20% after deploying 5 Formic palletizers</p></div>
      <div class="big-stat"><span class="bsn">$0</span><span class="bsl">CapEx Required</span><p class="bsd">Every Formic deployment is fully funded through monthly OpEx — no capital at risk</p></div>
      <div class="big-stat"><span class="bsn">24/7</span><span class="bsl">Tech Support</span><p class="bsd">Bilingual technical support and remote diagnostics around the clock, every day</p></div>
      <div class="big-stat"><span class="bsn">2wk</span><span class="bsl">Avg. Deployment</span><p class="bsd">From signed agreement to running production in weeks, not months</p></div>
    </>
  )}
</div>

<!-- OUTCOME 1: LABOR -->
<section id="labor" class="bg-lgrey" style="padding:2px 0">
  <div class="outcome-section rv">
    <div class="os-text">
      <div class="slabel">01 — Labor Shortage</div>
      <h2>Fill the gaps<br>automation can't quit.</h2>
      <p class="btext">Chronic labor shortages are forcing mid-market manufacturers to leave capacity on the floor. Formic automates the positions that are hardest to fill and fastest to turn over — permanently.</p>
      <ul class="evidence-list">
        <li>Eliminates dependency on hard-to-fill, high-turnover positions at end-of-line</li>
        <li>Frees existing workers for higher-value inspection, quality, and supervisory roles</li>
        <li>No recruiting, onboarding, or training costs for automated positions</li>
        <li>Consistent throughput regardless of shift attendance or seasonal availability</li>
      </ul>
      <a href="/customers" class="larr">See customer stories →</a>
    </div>
    <div class="os-img">
      <img src="/R52_5359.jpg" alt="Formic FSE deploying system — labor automation" loading="lazy">
    </div>
  </div>
</section>

<!-- OUTCOME 2: INJURY -->
<section id="injury" class="bg-white" style="padding:2px 0">
  <div class="outcome-section rv">
    <div class="os-img">
      <img src="/Focus-7603.jpg" alt="Formic palletizer replacing manual lifting tasks" loading="lazy">
    </div>
    <div class="os-text">
      <div class="slabel">02 — Ergonomic Injury</div>
      <h2>Remove people<br>from harm's way.</h2>
      <p class="btext">Repetitive palletizing, case stacking, and machine loading are among the leading causes of workplace injury in manufacturing. Formic removes workers from these tasks entirely.</p>
      <ul class="evidence-list">
        <li>Eliminates repetitive lifting, reaching, and twisting injuries at end-of-line</li>
        <li>Reduces workers' comp claims and associated insurance costs</li>
        <li>Improves worker retention — people stay where they're not getting hurt</li>
        <li>OSHA compliance becomes simpler when the highest-risk tasks are automated</li>
      </ul>
      <a href="/customers" class="larr">See customer stories →</a>
    </div>
  </div>
</section>

<!-- OUTCOME 3: PRODUCTIVITY — with GIF -->
<section id="productivity" class="bg-lgrey" style="padding:2px 0">
  <div class="outcome-section rv">
    <div class="os-text">
      <div class="slabel">03 — Productivity Gains</div>
      <h2>Consistent output.<br>Every shift.</h2>
      <p class="btext">Human throughput varies by fatigue, breaks, and morale. Formic systems run at contracted performance rates, every cycle, every shift — and Formic Production Intelligence shows you exactly how.</p>
      <ul class="evidence-list">
        <li>Contracted performance rates — not estimates, but SLA-backed guarantees</li>
        <li>Real-time OEE and throughput data from every deployed system</li>
        <li>Faster changeovers through pre-programmed product configurations</li>
        <li>Continuous optimization from software updates over the life of the system</li>
      </ul>
      <a href="/platform#fpi" class="larr">See FPI Analytics →</a>
    </div>
    <div class="os-img">
      <img src="/Haviland_Products_-_Palletizing.gif" alt="Formic palletizer running at consistent production rate">
    </div>
  </div>
</section>

<!-- OUTCOME 4: COST -->
<section id="cost" class="bg-white" style="padding:2px 0">
  <div class="outcome-section rv">
    <div class="os-img">
      <img src="/Talos-9787.jpg" alt="Formic engineer monitoring system performance and cost data" loading="lazy">
    </div>
    <div class="os-text">
      <div class="slabel">04 — Cost Savings</div>
      <h2>OpEx beats<br>CapEx every time.</h2>
      <p class="btext">Traditional automation requires capital investment, internal engineering, and ongoing maintenance — all funded upfront. Formic flips the model: one fixed monthly price covers everything.</p>
      <ul class="evidence-list">
        <li>Zero capital required — no depreciation, no balance sheet impact</li>
        <li>Predictable monthly cost replaces variable labor and maintenance spend</li>
        <li>No internal engineering resources needed for deployment or support</li>
        <li>Flexible agreements — swap or add systems as your production mix changes</li>
        <li>Land O'Frost achieved 20% OpEx reduction within first year of deployment</li>
      </ul>
      <a href="/full-service#pricing" class="larr">See pricing →</a>
    </div>
  </div>
</section>

<!-- VIDEO SECTION with ATLAS EOAT webm -->
<section class="bg-black" style="padding:0">
  <div style="position:relative;height:75vh;min-height:500px;overflow:hidden">
    <video autoplay muted loop playsinline id="heroVid" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0">
      <source src="/ATLAS_EOAT.webm" type="video/webm">
    </video>
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(9,21,23,.8) 0%,rgba(9,21,23,.2) 60%);z-index:1"></div>
    <div style="position:absolute;bottom:0;left:0;right:0;padding:56px 80px;z-index:2">
      <div class="mono-label" style="color:var(--orange)">In Action</div>
      <h2 class="dtitle wh" style="font-size:clamp(36px,4.5vw,60px);max-width:640px">This is what full-service automation looks like on your floor.</h2>
    </div>
    <button id="muteBtn" class="video-mute" onclick="initVideoMute()">Unmute</button>
  </div>
</section>

<!-- CTA -->
<div class="cta-band rv">
  <h2>Ready to see<br>these results?</h2>
  <div class="cta-band-btns">
    <a href="/company#demo" class="btn-dark">Get a Demo</a>
    <a href="/customers" class="btn-wh-border">Customer Stories</a>
  </div>
</div>

  <script is:inline slot="scripts">
function initVideoMute(){
  const btn=document.getElementById('muteBtn');
  const vid=document.getElementById('heroVid');
  if(!btn||!vid)return;
  vid.muted=!vid.muted;
  btn.textContent=vid.muted?'Unmute':'Mute';
}
  </script>
</Layout>
