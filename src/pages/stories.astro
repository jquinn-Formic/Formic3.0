---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Customer Stories — Formic" description="How real CPG and manufacturing operators put Formic to work." ogTitle="Customer Stories" ogDescription="How real CPG and manufacturing operators put Formic to work.">
  <link rel="canonical" href="https://formic.co/stories" slot="head" />
  <style is:global slot="head">
    [data-card]{transition:background .2s ease}
    [data-card]:hover{background:var(--lgrey)}
    [data-card]:hover img{transform:scale(1.04)}
  </style>

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span>Customer Stories
</div>

<section class="detail-hero">
  <div class="si">
    <div class="slabel" style="color:var(--orange)">Customer Stories</div>
    <h1>Proven on <em>real floors</em>.</h1>
    <p class="lede">How real CPG and manufacturing operators put Formic to work — 22 from the Formic team.</p>
  </div>
</section>

