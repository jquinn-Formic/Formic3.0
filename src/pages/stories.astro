---
import Layout from '../layouts/Layout.astro';
const stories = [{"slug": "kari-out", "title": "25% More Output, Zero Stress: How Kari-Out Automated Palletizing Without CapEx", "category": "Case Packing", "date_short": "Mar 11, 2026", "hero": "/stories/kari-out/1773269635-pod_landofrost-2.jpg"}, {"slug": "mattpak", "title": "Meeting Every Customer Need: How MattPak Scaled with Automation", "category": "Palletizing", "date_short": "Jan 14, 2026", "hero": "/stories/mattpak/1758727398-mattkunach-mattpak.jpg"}, {"slug": "marquis", "title": "Innovation in Their DNA: Marquis Automates Palletizing to Drive Efficiency and Support Employee Well-Being", "category": "Robotics", "date_short": "Dec 16, 2025", "hero": "/stories/marquis/1765917001-pxl_20251119_144149571-3-1.jpg"}, {"slug": "masters-gallery", "title": "When Leadership and Employees Align: Masters Gallery Automates Palletizing to Make Work Better for Everyone", "category": "Palletizing", "date_short": "Dec 10, 2025", "hero": "/stories/masters-gallery/1765387022-r52_6416-1.jpg"}, {"slug": "taffy-town", "title": "From Hand-Stacking to 5.5 Million Pounds Automated & Counting: How Taffy Town Scaled with Formic", "category": "Palletizing", "date_short": "Nov 21, 2025", "hero": "/stories/taffy-town/1763757449-taffytown-0219.jpg"}, {"slug": "sunrise-family-farms", "title": "How Sunrise Family Farms Is Using Automation to Preserve Tradition and Scale Smarter", "category": "Palletizing", "date_short": "Sep 2, 2025", "hero": "/stories/sunrise-family-farms/1756826112-screenshot-2025-09-02-at-8-15-01-am-2.png"}, {"slug": "alta-foods", "title": "Charting the Future: ALTA Foods Expands Automation to Strengthen Operations", "category": "Palletizing", "date_short": "Aug 4, 2025", "hero": "/stories/alta-foods/1754323262-fiesta-fit-deli-line-1.jpg"}, {"slug": "wyandot-snacks", "title": "90 Years of Snacks, Now Built for Agility: Wyandot Snacks Automates to Scale Production", "category": "Palletizing", "date_short": "Aug 4, 2025", "hero": "/stories/wyandot-snacks/1754318963-unnamed.jpg"}, {"slug": "boxed-water", "title": "How Boxed Water Is Taking the Strain Out of the Line with Automation", "category": "Palletizing", "date_short": "Jul 7, 2025", "hero": "/stories/boxed-water/1751905489-boxed-water-2.png"}, {"slug": "venus-wafers", "title": "Venus Wafers Cracks the Smart Manufacturing Code with Automated Palletizing", "category": "Palletizing", "date_short": "Jul 7, 2025", "hero": "/stories/venus-wafers/1751904149-upperleft.jpg"}, {"slug": "uncle-crumbles", "title": "How Automation Is Powering the Next Chapter at Uncle Crumbles", "category": "Palletizing", "date_short": "Jun 9, 2025", "hero": "/stories/uncle-crumbles/1749483799-screenshot-2025-06-09-at-8-43-04-am.png"}, {"slug": "rumiano-cheese", "title": "Rumiano Automates with Formic to Drive Community, Culture, & Organic Cheese Dominance", "category": "Palletizing", "date_short": "Apr 14, 2025", "hero": "/stories/rumiano-cheese/1745598936-rumiano-1.jpg"}, {"slug": "taffy-town-innovation", "title": "How Taffy Town Stretched Innovation Further with Automation", "category": "Palletizing", "date_short": "Mar 10, 2025", "hero": "/stories/taffy-town-innovation/1741640314-formic-logo-for-taffytown.jpg"}, {"slug": "land-o-frost", "title": "Land O’Frost Enhances Production with 5 Robotic Gantry Palletizers", "category": "Palletizing", "date_short": "Jan 10, 2025", "hero": "/stories/land-o-frost/1736544598-unnamed.jpg"}, {"slug": "mi-rancho", "title": "Mi Rancho Makes Production Leap with Automated Stacking of Millions of Tortillas per Year", "category": "Palletizing", "date_short": "Jun 5, 2024", "hero": "/stories/mi-rancho/1717609049-formic-mi-rancho-photos-4-of-17.jpg"}, {"slug": "camerons-coffee", "title": "Cameron’s Coffee Hits Automation “Easy Button”, Scaling from 0 to 5 Systems in 12 Months", "category": "Palletizing", "date_short": "Jun 3, 2024", "hero": "/stories/camerons-coffee/1717416326-camerons-with-formic-logo.png"}, {"slug": "polysciences", "title": "Chemical Manufacturing Leader Polysciences Partners With Formic to Introduce Automation To Their Production Process", "category": "Palletizing", "date_short": "Nov 13, 2023", "hero": "/stories/polysciences/1699882076-formic-polysciences-10.jpg"}, {"slug": "3d-machine", "title": "3D Machine Finds New Competitive Edge with Automation Partner Formic", "category": "Robotics", "date_short": "Aug 30, 2023", "hero": "/stories/3d-machine/1693406230-tim-deno-and-3d-machine.jpg"}, {"slug": "icon-injection-molding", "title": "ICON Injection Molding Deploys Formic Tend to Boost Production by 20% with Automation Partnership that is “Too Good to be True”", "category": "Robotics", "date_short": "Jun 26, 2023", "hero": "/stories/icon-injection-molding/1687784064-icon-injection-molding-deploys-formic-tend-to-boost-production-by-20-percent.jpg"}, {"slug": "compact-industries", "title": "Compact Industries Partners with Formic to Combat Labor Shortages and Accelerate Factory Productivity", "category": "Robotics", "date_short": "Jan 25, 2023", "hero": "/stories/compact-industries/1666195498-my-project-1-1.png"}, {"slug": "georgia-nut", "title": "Georgia Nut and Formic Deploy First Robot in Company's History", "category": "Customer Story", "date_short": "Jan 24, 2023", "hero": "/stories/georgia-nut/1642517481-screen-shot-2022-01-14-at-2-49-19-pm.png"}, {"slug": "polar-manufacturing", "title": "Polar Manufacturing and Formic Partner to Overcome Legacy Equipment Challenges and Boost Productivity", "category": "Automation", "date_short": "Jan 23, 2023", "hero": "/stories/polar-manufacturing/1633470848-screen-shot-2021-10-05-at-2-53-51-pm.png"}];
// Featured = the three most recent stories (stories array is ordered desc by pub date).
const featured = stories.slice(0, 3).map((s) => s.slug);
const feat = stories.filter((x) => featured.includes(x.slug));
const rest = stories.filter((x) => !featured.includes(x.slug));
---
<Layout title="Customer Stories — Formic" description="How real CPG and manufacturing operators put Formic to work." ogTitle="Customer Stories" ogDescription="How real CPG and manufacturing operators put Formic to work.">
  <link rel="canonical" href="https://formic.co/stories" slot="head" />
  <style is:global slot="head">
    [data-card]{transition:background .2s ease}
    [data-card]:hover{background:var(--lgrey)}
    [data-card]:hover img{transform:scale(1.04)}
  </style>

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span>Customer Stories
</div>

<section class="detail-hero">
  <div class="si">
    <div class="slabel" style="color:var(--orange)">Customer Stories</div>
    <h1>Proven on <em>real floors</em>.</h1>
    <p class="lede">Customer stories from CPG and manufacturing operators across the U.S. Robotic palletizing, case packing, and end-of-line automation in production today.</p>
  </div>
</section>

{feat.length > 0 && (
  <section class="detail-block white" style="padding:80px 80px 0">
    <div style="max-width:1280px;margin:0 auto">
      <div class="db-tag">Featured</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:1px;background:var(--lgrey);border:1px solid var(--lgrey);margin-top:14px">
        {feat.map((s) => (
          <a data-card href={`/stories/${s.slug}`} style="display:flex;flex-direction:column;background:var(--white);text-decoration:none">
            <div style="aspect-ratio:16/9;overflow:hidden;background:var(--black)">
            {s.hero && s.hero.endsWith('.mp4')
              ? <video src={s.hero} autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;display:block"></video>
              : (s.hero ? <img src={s.hero} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease"/> : <span style="display:block;width:100%;height:100%"></span>)}
          </div>
          <div style="padding:18px 20px 22px;display:flex;flex-direction:column;gap:9px">
            <div style="font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange)">{s.date_short}</div>
            <div style="font-family:var(--sans);font-size:17px;font-weight:600;letter-spacing:-.01em;color:var(--black);line-height:1.28">{s.title}</div>
          </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<section class="detail-block white" style="padding:80px">
  <div id="rest-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--lgrey);max-width:1280px;margin:0 auto;border:1px solid var(--lgrey)">
    {rest.map((s, i) => (
      <a data-card data-i={i} href={`/stories/${s.slug}`} style={"flex-direction:column;background:var(--white);text-decoration:none;display:" + (i < 8 ? "flex" : "none")}>
        <div style="aspect-ratio:16/9;overflow:hidden;background:var(--black)">
            {s.hero && s.hero.endsWith('.mp4')
              ? <video src={s.hero} autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;display:block"></video>
              : (s.hero ? <img src={s.hero} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease"/> : <span style="display:block;width:100%;height:100%"></span>)}
          </div>
          <div style="padding:18px 20px 22px;display:flex;flex-direction:column;gap:9px">
            <div style="font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange)">{s.date_short}</div>
            <div style="font-family:var(--sans);font-size:17px;font-weight:600;letter-spacing:-.01em;color:var(--black);line-height:1.28">{s.title}</div>
          </div>
      </a>
    ))}
  </div>
  {rest.length > 8 && (
    <div style="display:flex;justify-content:center;padding:44px 0 0">
      <button id="load-more" type="button" style="font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--black);background:var(--white);border:1px solid var(--lgrey);padding:14px 28px;cursor:pointer;display:inline-flex;align-items:center;gap:10px">Show more <span aria-hidden="true" style="color:var(--orange);font-size:14px;line-height:1">▾</span></button>
    </div>
  )}
</section>

<section class="detail-cta">
  <h2>Your floor. <em>Your results.</em></h2>
  <p style="font-family:var(--sans);font-size:17px;font-weight:300;color:rgba(9,21,23,.7);max-width:560px;margin:-8px auto 28px;line-height:1.5">Talk to an engineer about what automation looks like for your operation.</p>
  <div class="btn-row">
    <a href="mailto:sales@formic.co" class="btn-ctadark">Get Started</a>
    <a href="/articles" class="btn-ctawh">Read the blog</a>
  </div>
</section>

<script is:inline>
(function () {
  var grid = document.getElementById("rest-grid");
  var btn = document.getElementById("load-more");
  if (!grid || !btn) return;
  var cards = Array.prototype.slice.call(grid.querySelectorAll("[data-i]"));
  var shown = 8, step = 8;
  btn.addEventListener("click", function () {
    shown += step;
    cards.forEach(function (c) { if (Number(c.getAttribute("data-i")) < shown) c.style.display = "flex"; });
    if (shown >= cards.length) btn.style.display = "none";
  });
})();
</script>
</Layout>
