---
import Layout from '../layouts/Layout.astro';

const values = [
  { n: "01", name: "Fearless Optimism", tag: "Strive forward with confidence.",
    icon: '<circle cx="12" cy="12" r="4.2"/><path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8l1.8-1.8M18 6l1.8-1.8"/>',
    body: ["Formic exists to create a world of abundance by outsourcing the drudgery of work to robots so that humans can be unleashed to do the creative, imaginative, collaborative, satisfying, society-advancing work we’re meant to do.", "Realizing our mission will require us to rethink the status quo, stay on the cusp of today’s innovations, solve really hard technical and operational problems, and most importantly, remain fearlessly optimistic while we do it.", "We’re in an old space doing new things and aspiring to new heights. Instead of thinking about all the small ways something won’t work, we think about all the big ways something can. We lean on the experience and perspective of our team mates coming from other industries to learn what is possible – this mix of viewpoints is one of our greatest strengths. The path forward might not always be immediately obvious–it’s still early days for Formic–but if we focus on our mission in everything we do, every day, we’ll always be headed in the right direction. We will create a world of abundance with the world’s largest robot workforce."] },
  { n: "02", name: "Create the Magic", tag: "Traditional automation is hard. Formic is easy.",
    icon: '<path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z"/><path d="M18.5 14l.9 2.1 2.1.9-2.1.9-.9 2.1-.9-2.1-2.1-.9 2.1-.9z"/>',
    body: ["We exist to absorb complexity. We communicate with clarity. We are surprisingly, unexpectedly fast. We understand our robots are critical to the customers’ production. That is a responsibility we take seriously.", "We are partners, not vendors. If the robot stops, we stop getting paid—our incentives are perfectly aligned with our customers’ production. We take on the responsibility of our robots being critical to your operation. We always choose to take the burden rather than make the customer experience worse. We communicate clearly, move with speed, and simplify operational and financial decisions, providing a superior experience to just buying a robot."] },
  { n: "03", name: "TNT — Today, Not Tomorrow", tag: "Aspire to work efficiently.",
    icon: '<path d="M13 2L4.5 13.5H11l-1 8.5L19.5 10.5H13z"/>',
    body: ["The only way to do the industry-shaping, tide-raising, high-impact work we are here to do is to deliver great work at a steady clip. As Kevin Kelly said, “many backward steps are made by standing still.” We must take decisive steps forward, as often as we can.", "We’ll get there by taking accountability for our work, staying focused on what matters, and seeing things through to completion no matter what it takes to deliver on our promises. We refuse to be blocked, even when it’s unpleasant. We aspire to work efficiently and we’ll prioritize ruthlessly to get there by constantly asking ourselves if the “juice is worth the squeeze”. There will be times we have to say no to work and people we really, really want to say yes to. Those moments might be painful, but we have to constantly remind ourselves it’s worth the space it opens up for us to execute exceedingly well on the things that matter. We own our own work and our focus.", "There will be times when the work in front of us feels big and hard to wrangle. So, we’ll break it up into smaller, more manageable pieces, polish them up, and get them out the door. (It’ll help us learn sooner and more often, anyway). We bias towards getting things done. We help our colleagues keep that spirit up, too.", "We do all this without being asked or told, because that’s the kind of company, product, and reputation we all want to uphold together. This company is ours to build together. We’re still the underdog, but if we keep shipping great stuff and building great habits around urgency and focus, soon, the Formic way will become the most obvious way for a factory to build their workforce."] },
  { n: "04", name: "Seek Truth", tag: "Know the WHY behind the decision.",
    icon: '<circle cx="12" cy="12" r="9.2"/><path d="M16 8l-2.6 5.4L8 16l2.6-5.4z"/>',
    body: ["To build trust, we must be predictable. Ambiguity is the enemy of scale. Whether architecting Formic Core or managing a deployment, we work from first principles to find the right answer, not the popular one.", "We champion the best decision, driven by truth and objective data, regardless of who proposes it. We operate without ego: if presented with new evidence, we readily abandon previous opinions. We actively pursue truth, even when it means challenging others. We debate thoroughly to reach the best conclusion. We embrace conflict solely in service of the truth, and never make it personal."] },
  { n: "05", name: "Made of Rubber", tag: "Be flexible enough to meet any challenge.",
    icon: '<path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4.5V9h4.5"/>',
    body: ["Think about the things around you that are made of rubber – tires, the soles of our shoes, pet toys, bouncy balls, brake pads, windshield wipers, medical gloves, balloons, surfaces of playgrounds, hoses. Now think of how reliable these things are across so many different use-cases, whether it’s rain or shine, or whether we’re walking, driving or biking, playing or working. Rubber does the trick because it is simultaneously incredibly durable and incredibly resilient.", "At Formic, we work like rubber; when we fall we bounce back up. Dropping something shouldn’t necessarily mean breaking it. We are flexible enough to meet all kinds of challenges and are strong enough to get through them without falling apart. We should be able to move over gravel with grace. Everyday pokes and prods and pushes shouldn’t throw us off our game. When they come, we should be able to absorb them and reclaim our shape in no time…or, mold ourselves to the new normal if that’s what’s needed.", "There’s going to be a lot thrown at us in the days, months, and years to come. We aspire to take it all in stride, with a spring in our step."] },
  { n: "06", name: "One Formic", tag: "We only win when we win together.",
    icon: '<circle cx="9" cy="8" r="3.1"/><path d="M3.5 19c0-3 2.4-5 5.5-5s5.5 2 5.5 5"/><path d="M16 6.6a3 3 0 0 1 0 5.8"/><path d="M17 14.2c2.4.4 3.8 2.2 3.8 4.8"/>',
    body: ["At Formic, we always work with a desire to make things easier and better for other team members. In a fast-paced, quickly-scaling organization like ours, a graceful baton pass is an act of kindness.", "We are judicious with our asks, mindful of the costs of internal requests, and look for opportunities to be proactively helpful. We think about how to make useful information available to our colleagues (ex- in well-curated, discoverable documentation). If it’s buried in a Slack thread, it’s probably not usefully available. We unblock others and are responsive to help them sprint.", "Before you ask someone else to do something (or even just give them an idea), consider, whether it’s actually important that they hear from you about this, whether now is the right time and whether this is the right forum (and if not, when/how?). When you’re on the receiving end of an idea, relentlessly determine who is the decision-maker, what the action is, and whether you are going to take action on it. Get comfortable with (the good kind of) process - they help us run more smoothly. Respect those others have established and honor the inkling that something you’re working on might require one.", "Be generous with useful information. Share resources, tools, and tips that are likely to accelerate someone else’s progress. Make teaching and learning a part of your day, every day. Much of our work requires that we “stitch together” disparate areas (mechanical engineering, software, finance, legal, etc.). Helping each other lets us continue to build a better solution as we “connect” and produce seamless solutions using multiple disciplines and knowledge areas."] },
];

const testimonials = [
  { photo: "/careers/arti-brannon.jpg", name: "Arti Brannon", role: "Sales Development Representative",
    quote: "Automation can be such a black box for manufacturers. At Formic, we shoulder that uncertainty for our customers and work together behind the scenes to make deployments feel like magic. It takes a joint effort - and certainly it takes good baton passes - among a great group of people to make it all happen; I am so happy to be a part of the team doing it all." },
  { photo: "/careers/brian-jaworski.jpg", name: "Brian Jaworski", role: "Solutions Engineer",
    quote: "I enjoy digging into the technical details to craft the perfect automation solution. It’s all about problem-solving and making sure every system delivers real, lasting impact." },
  { photo: "/careers/katherine-coco.jpg", name: "Katherine Coco", role: "Director of FP&A and Accounting",
    quote: "Every day at Formic is challenging and exciting. We’re constantly learning and working together to create something that has never been done before." },
  { photo: "/careers/josh-huang.jpg", name: "Josh Huang", role: "Robotics Deployment Project Manager",
    quote: "Bringing automation to life on the factory floor is the best part of my job. I love training teams and seeing their excitement when the robots start running." },
  { photo: "/careers/sylvia-domanico.jpg", name: "Sylvia Domanico", role: "Automation Sales Manager",
    quote: "I love helping customers see how easy automation can be. It’s exciting to turn hesitation into confidence and show them a path to real productivity gains." },
  { photo: "/careers/danielle-vigent.jpg", name: "Danielle Vigent", role: "Automation Solutions Engineer",
    quote: "What makes my role at Formic unique is the speed and direct involvement at which we iterate and execute, allowing us to put advanced robotics directly into production to solve our clients' most pressing operational challenges fast." },
];
---
<Layout
  title="Careers — Formic"
  description="Join Team Formic — a people-first robotics company on a mission to bring automation to those who need it most. See our culture, values, and open roles."
  ogTitle="Join Team Formic — Careers"
  ogDescription="A people-first robotics company. See our culture, values, and open roles."
>
  <link rel="canonical" href="https://formic.co/careers" slot="head" />
  <style is:global slot="head">
    .cr-slider{position:relative;max-width:1280px;margin:0 auto}
    .cr-bar{height:2px;background:rgba(127,131,121,.22);overflow:hidden;margin-bottom:22px}
    .cr-bar > span{display:block;height:100%;width:0;background:var(--orange);box-shadow:0 0 8px rgba(255,145,0,.55)}
    .cr-track{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;scrollbar-width:none;-ms-overflow-style:none;padding-bottom:4px;align-items:flex-start}
    .cr-track::-webkit-scrollbar{display:none}
    .cr-vtile{flex:0 0 clamp(260px,80vw,380px);scroll-snap-align:start;background:var(--white);padding:30px 30px 26px;display:flex;flex-direction:column;gap:12px;position:relative;height:264px;overflow:hidden}
    .cr-vicon{width:44px;height:44px;color:var(--orange);display:flex;align-items:center;justify-content:center;border:1px solid var(--lgrey)}
    .cr-vnum{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.22em;color:var(--mgrey)}
    .cr-vname{font-family:var(--sans);font-size:21px;font-weight:600;letter-spacing:-.015em;color:var(--black);line-height:1.12}
    .cr-vtag{font-family:var(--sans);font-size:14px;font-weight:500;font-style:italic;color:var(--orange);margin-bottom:2px}
    .cr-vtoggle{position:absolute;left:30px;bottom:24px;z-index:3;width:30px;height:30px;border:1px solid var(--lgrey);background:var(--white);color:var(--orange);font-size:20px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .3s ease,background .2s}
    .cr-vtoggle:hover{background:var(--lgrey)}
    .cr-vtile.open .cr-vtoggle{transform:rotate(45deg)}
    .cr-vbody{position:absolute;inset:0;background:var(--white);padding:28px 30px 60px;overflow-y:auto;opacity:0;visibility:hidden;transition:opacity .3s ease;z-index:2}
    .cr-vtile.open .cr-vbody{opacity:1;visibility:visible}
    .cr-vbody p{font-family:var(--sans);font-size:14px;font-weight:300;line-height:1.65;color:var(--mgrey);margin:0 0 12px}
    .cr-qtile{flex:0 0 clamp(280px,78vw,400px);scroll-snap-align:start;background:var(--dgrey);padding:26px 28px 24px;display:flex;flex-direction:column;gap:18px}
    .cr-qtext{font-family:var(--sans);font-size:15px;font-weight:300;font-style:italic;line-height:1.55;color:var(--white);margin:0}
    .cr-qrow{display:flex;align-items:center;gap:13px}
    .cr-qrow img{width:46px;height:46px;border-radius:50%;object-fit:cover;flex-shrink:0;background:var(--black)}
    .cr-qname{font-family:var(--sans);font-size:14px;font-weight:600;color:var(--white)}
    .cr-qrole{font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--orange);margin-top:3px}
    .cr-jump{display:inline-flex;align-items:center;gap:12px;margin-top:34px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:rgba(240,245,241,.85);text-decoration:none}
    .cr-jump:hover{color:var(--white)}
    .cr-jump .cr-jump-arrow{display:flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid rgba(240,245,241,.3);border-radius:50%;color:var(--orange);font-size:15px;animation:cr-bounce 1.8s ease-in-out infinite;transition:border-color .2s}
    .cr-jump:hover .cr-jump-arrow{border-color:var(--orange)}
    @keyframes cr-bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}
    .cr-filters{display:flex;gap:12px;flex-wrap:wrap;margin:24px 0 18px}
    .cr-filters select{font-family:var(--mono);font-size:12px;letter-spacing:.04em;color:var(--black);background:var(--white);border:1px solid var(--lgrey);padding:10px 14px;cursor:pointer}
    .cr-job{display:flex;align-items:center;justify-content:space-between;gap:24px;background:var(--white);border:1px solid var(--lgrey);border-top:none;padding:22px 26px;text-decoration:none;transition:background .2s}
    .cr-job:first-child{border-top:1px solid var(--lgrey)}
    .cr-job:hover{background:var(--lgrey)}
    .cr-job .cr-jtitle{font-family:var(--sans);font-size:18px;font-weight:600;letter-spacing:-.01em;color:var(--black)}
    .cr-job .cr-jmeta{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--mgrey);margin-top:6px}
    .cr-job .cr-jarrow{font-family:var(--sans);font-size:22px;color:var(--orange);flex-shrink:0}
    .cr-empty{font-size:15px;font-weight:300;color:var(--mgrey);padding:32px 4px}
    .cr-prose-d p{font-size:17px;font-weight:300;line-height:1.75;color:rgba(240,245,241,.72);margin:0 0 18px;max-width:820px}
  </style>

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span><a href="/learn-more">Our Mission</a><span class="sep">/</span>Careers
</div>

<section class="detail-hero">
  <div class="si">
    <div class="slabel" style="color:var(--orange)">Careers</div>
    <h1>Join Team <em>Formic</em>.</h1>
    <p class="lede">We're building the operating layer of physical industry and we're looking for the people who want to do work that actually matters.</p>
    <a href="#openings" class="cr-jump" aria-label="Jump to open roles"><span>See open roles</span><span class="cr-jump-arrow" aria-hidden="true">↓</span></a>
  </div>
</section>

<section class="detail-block dark" style="padding:8px 24px 16px">
  <figure style="max-width:760px;margin:0 auto;position:relative">
    <img src="/careers/team-onsite.jpg" alt="The Formic team on-site" style="width:100%;height:auto;display:block"/>
    <figcaption style="position:absolute;left:14px;bottom:12px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:rgba(240,245,241,.85);text-shadow:0 1px 6px rgba(0,0,0,.6)">Team Formic · on-site</figcaption>
  </figure>
</section>

<section class="detail-block dark">
  <div class="si" style="max-width:1280px;margin:0 auto;padding:72px 24px">
    <div class="db-tag">Our mission</div>
    <h2 style="font-family:var(--sans);font-size:clamp(32px,4vw,56px);font-weight:500;letter-spacing:-.02em;line-height:1.05;color:var(--white);margin:8px 0 26px">Our mission is <em style="color:var(--orange);font-style:normal">ambitious</em>.</h2>
    <div class="cr-prose-d">
      <p>We want to fundamentally change how automation is deployed and dramatically increase adoption across every manufacturer that needs it. We're building an organization meant to last generations, where the people here today become the leaders of tomorrow. That takes a unified standard for how we work: not just what we ship, but how we show up, how we communicate, and how we raise the bar on everything we touch.</p>
    </div>
  </div>
</section>

<section class="detail-block lgrey">
  <div class="si" style="max-width:1280px;margin:0 auto;padding:72px 24px">
    <div class="db-tag">Our Values</div>
    <h2 style="font-family:var(--sans);font-size:clamp(30px,3.6vw,48px);font-weight:500;letter-spacing:-.02em;line-height:1.06;color:var(--black);margin:8px 0 26px">Six values, <em style="color:var(--orange);font-style:normal">one Formic</em>.</h2>
    <div class="cr-slider" id="values-slider" data-interval="7000">
      <div class="cr-bar"><span></span></div>
      <div class="cr-track">
        {values.map((v) => (
          <article class="cr-vtile">
            <div class="cr-vicon"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={v.icon}></svg></div>
            <div class="cr-vnum">{v.n}</div>
            <div class="cr-vname">{v.name}</div>
            <div class="cr-vtag">{v.tag}</div>
            <button class="cr-vtoggle" type="button" aria-expanded="false" aria-label={`Expand ${v.name}`}>+</button>
            <div class="cr-vbody">{v.body.map((p) => (<p>{p}</p>))}</div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="detail-block dark">
  <div class="si" style="max-width:1280px;margin:0 auto;padding:72px 24px">
    <div class="db-tag">In their words</div>
    <h2 style="font-family:var(--sans);font-size:clamp(30px,3.6vw,48px);font-weight:500;letter-spacing:-.02em;line-height:1.06;color:var(--white);margin:8px 0 26px">Life as a <em style="color:var(--orange);font-style:normal">Formican</em>.</h2>
    <div class="cr-slider" id="quotes-slider" data-interval="6000">
      <div class="cr-bar"><span></span></div>
      <div class="cr-track">
        {testimonials.map((t) => (
          <article class="cr-qtile">
            <p class="cr-qtext">“{t.quote}”</p>
            <div class="cr-qrow">
              <img src={t.photo} alt={t.name} width="52" height="52"/>
              <div><div class="cr-qname">{t.name}</div><div class="cr-qrole">{t.role}</div></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="detail-block white" id="openings">
  <div class="si" style="max-width:1080px;margin:0 auto;padding:72px 24px">
    <div class="db-tag">Current Openings</div>
    <h2 style="font-family:var(--sans);font-size:clamp(30px,3.6vw,48px);font-weight:500;letter-spacing:-.02em;line-height:1.06;color:var(--black);margin:8px 0 4px">Open roles at Formic.</h2>
    <div class="cr-filters">
      <select id="jobs-loc" aria-label="Filter by location"><option value="">All locations</option></select>
      <select id="jobs-team" aria-label="Filter by team"><option value="">All teams</option></select>
    </div>
    <div id="jobs-list"><p class="cr-empty">Loading open roles…</p></div>
  </div>
</section>

<section class="detail-block lgrey">
  <div class="si" style="max-width:920px;margin:0 auto;padding:72px 24px">
    <div class="db-tag">Why join</div>
    <h2 style="font-family:var(--sans);font-size:clamp(30px,3.6vw,48px);font-weight:500;letter-spacing:-.02em;line-height:1.06;color:var(--black);margin:8px 0 22px">A people-first <em style="color:var(--orange);font-style:normal">robotics company</em>.</h2>
    <p style="font-size:16px;font-weight:300;line-height:1.75;color:var(--mgrey);margin:0 0 22px">We're a cross-functional team of engineers, roboticists, salespeople, operators, and finance experts hand-picked and working toward the same mission. Some of the sharpest minds in automation, doing work that shows up on real factory floors.</p>
    <p style="font-size:16px;font-weight:300;line-height:1.75;color:var(--mgrey);margin:0 0 14px"><strong style="color:var(--black);font-weight:600">Flexible time off:</strong> FTO policy bundling vacation and personal time. We trust our people to know when they need it.</p>
    <p style="font-size:16px;font-weight:300;line-height:1.75;color:var(--mgrey);margin:0 0 14px"><strong style="color:var(--black);font-weight:600">Remote-first:</strong> headquartered in Chicago, but your home is your office. Every new hire gets a new computer and a generous budget to build a setup that works.</p>
    <p style="font-size:16px;font-weight:300;line-height:1.75;color:var(--mgrey);margin:0"><strong style="color:var(--black);font-weight:600">Full benefits:</strong> comprehensive medical, dental, and vision, plus a generous parental leave policy for new and newly adoptive parents.</p>
  </div>
</section>

<section class="detail-cta">
  <h2>Ready to <em>build with us?</em></h2>
  <div class="btn-row">
    <a href="#openings" class="btn-ctadark">See Open Roles</a>
    <a href="/learn-more" class="btn-ctawh">Our Mission</a>
  </div>
</section>

<script is:inline>
(function () {
  function initSlider(root) {
    var track = root.querySelector(".cr-track");
    var bar = root.querySelector(".cr-bar > span");
    if (!track) return;
    var tiles = track.children;
    var interval = Number(root.getAttribute("data-interval")) || 6000;
    var idx = 0, start = null, elapsed = 0, paused = false, frozen = false;
    function go(i) {
      idx = (i % tiles.length + tiles.length) % tiles.length;
      track.scrollTo({ left: tiles[idx].offsetLeft - tiles[0].offsetLeft, behavior: "smooth" });
    }
    function frame(ts) {
      if (paused || frozen) { start = ts - elapsed; requestAnimationFrame(frame); return; }
      if (start === null) start = ts;
      elapsed = ts - start;
      var p = Math.min(elapsed / interval, 1);
      if (bar) bar.style.width = (p * 100) + "%";
      if (p >= 1) { start = ts; elapsed = 0; go(idx + 1); }
      requestAnimationFrame(frame);
    }
    root.addEventListener("mouseenter", function () { paused = true; });
    root.addEventListener("mouseleave", function () { paused = false; });
    root.querySelectorAll(".cr-vtoggle").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var tile = btn.closest(".cr-vtile");
        var open = tile.classList.toggle("open");
        btn.setAttribute("aria-expanded", open ? "true" : "false");
        frozen = !!root.querySelector(".cr-vtile.open");
      });
    });
    // keep idx in sync if the user scrolls manually
    var st;
    track.addEventListener("scroll", function () {
      clearTimeout(st);
      st = setTimeout(function () {
        var base = tiles[0].offsetLeft, best = 0, bd = 1e9;
        for (var i = 0; i < tiles.length; i++) {
          var d = Math.abs((tiles[i].offsetLeft - base) - track.scrollLeft);
          if (d < bd) { bd = d; best = i; }
        }
        idx = best;
      }, 120);
    });
    requestAnimationFrame(frame);
  }
  ["values-slider", "quotes-slider"].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) initSlider(el);
  });
})();
</script>

<script is:inline>
(function () {
  var board = "formic";
  var listEl = document.getElementById("jobs-list");
  var locSel = document.getElementById("jobs-loc");
  var teamSel = document.getElementById("jobs-team");
  if (!listEl) return;
  var all = [];
  function uniq(a) { return Array.from(new Set(a)).filter(Boolean).sort(); }
  function esc(s) { return (s || "").replace(/[&<>"]/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]; }); }
  function render() {
    var loc = locSel.value, team = teamSel.value;
    var rows = all.filter(function (j) { return (!loc || j.location === loc) && (!team || j.team === team); });
    if (!rows.length) { listEl.innerHTML = '<p class="cr-empty">No open roles match these filters right now — check back soon, or reach out at <a href="mailto:careers@formic.co" style="color:var(--orange)">careers@formic.co</a>.</p>'; return; }
    listEl.innerHTML = rows.map(function (j) {
      return '<a class="cr-job" href="' + esc(j.url) + '" target="_blank" rel="noopener"><div><div class="cr-jtitle">' + esc(j.title) + '</div><div class="cr-jmeta">' + esc([j.team, j.location].filter(Boolean).join(" · ")) + '</div></div><span class="cr-jarrow">→</span></a>';
    }).join("");
  }
  function add(job, team) { all.push({ title: job.title, url: job.absolute_url, location: (job.location && job.location.name) || "", team: team || "" }); }
  fetch("https://boards-api.greenhouse.io/v1/boards/" + board + "/departments?render_as=tree")
    .then(function (r) { return r.json(); })
    .then(function (d) {
      (d.departments || []).forEach(function (dep) {
        (dep.jobs || []).forEach(function (j) { add(j, dep.name); });
        (dep.children || []).forEach(function (c) { (c.jobs || []).forEach(function (j) { add(j, c.name || dep.name); }); });
      });
      uniq(all.map(function (j) { return j.location; })).forEach(function (l) { var o = document.createElement("option"); o.value = l; o.textContent = l; locSel.appendChild(o); });
      uniq(all.map(function (j) { return j.team; })).forEach(function (t) { var o = document.createElement("option"); o.value = t; o.textContent = t; teamSel.appendChild(o); });
      render();
    })
    .catch(function () { listEl.innerHTML = '<p class="cr-empty">Unable to load open roles right now. Please email <a href="mailto:careers@formic.co" style="color:var(--orange)">careers@formic.co</a>.</p>'; });
  locSel.addEventListener("change", render);
  teamSel.addEventListener("change", render);
})();
</script>
</Layout>
