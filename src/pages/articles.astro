_short": "Jan 18, 2022", "hero": "/articles/formics-series-a-raise/1642518254-screen-shot-2022-01-14-at-2-48-17-pm.png"}, {"slug": "mandissa-marshall-the-startup-mentality", "title": "Mandissa Marshall, The Startup Mentality", "category": "Robotics", "date_short": "Jan 14, 2022", "hero": "/articles/mandissa-marshall-the-startup-mentality/1642269531-img_4477-edited.png"}, {"slug": "7-exciting-trends-in-industrial-automation", "title": "7 Exciting Trends in Industrial Automation", "category": "Robotics", "date_short": "Dec 20, 2021", "hero": "/articles/7-exciting-trends-in-industrial-automation/1640017462-shutterstock1967848108-edited-edited.png"}, {"slug": "why-do-customers-choose-formic", "title": "Why Do Customers Choose Formic?", "category": "Robotics", "date_short": "Nov 22, 2021", "hero": "/articles/why-do-customers-choose-formic/1614716002-foodbev.jpg"}, {"slug": "why-the-us-needs-to-automate-now", "title": "Why the U.S. Needs to Automate Now", "category": "Robotics", "date_short": "Nov 11, 2021", "hero": "/articles/why-the-us-needs-to-automate-now/1636663843-my-post-1.jpg"}, {"slug": "jack-wagler-formic-is-offering-a-service-like-uber", "title": "Jack Wagler: \"Formic is Offering a Service Like Uber\"", "category": "Robotics", "date_short": "Oct 22, 2021", "hero": "/articles/jack-wagler-formic-is-offering-a-service-like-uber/1634910595-dsc3561-edited.png"}, {"slug": "the-challenge-with-industry-40-that-no-one-is-talking-about", "title": "The Challenge with Industry 4.0 that No One is Talking About", "category": "Automation", "date_short": "Oct 19, 2021", "hero": "/articles/the-challenge-with-industry-40-that-no-one-is-talking-about/1634676882-my-post-10-edited.png"}, {"slug": "kyle-kidwell-an-engineering-perspective-on-automation", "title": "Kyle Kidwell, An Engineering Perspective on Automation", "category": "Robotics", "date_short": "Oct 15, 2021", "hero": "/articles/kyle-kidwell-an-engineering-perspective-on-automation/1634334305-dsc3492-edited.png"}, {"slug": "5-robotics-companies-revolutionizing-the-world-in-2021-part-2", "title": "5 Robotics Companies Revolutionizing the World in 2021 - Part 2", "category": "Robotics", "date_short": "Oct 11, 2021", "hero": "/articles/5-robotics-companies-revolutionizing-the-world-in-2021-part-2/1633973924-zipline.jpeg"}, {"slug": "saman-farid-the-co-founder-story", "title": "Saman Farid, The Co-Founder Story", "category": "Robotics", "date_short": "Oct 8, 2021", "hero": "/articles/saman-farid-the-co-founder-story/1633707642-dsc3227-edited.png"}, {"slug": "5-robotics-companies-revolutionizing-the-world-in-2021-part-1", "title": "5 Robotics Companies Revolutionizing the World in 2021 - Part 1", "category": "Robotics", "date_short": "Oct 4, 2021", "hero": "/articles/5-robotics-companies-revolutionizing-the-world-in-2021-part-1/1633375753-ironox2.jpg"}, {"slug": "misa-ilkhechi-the-co-founder-story", "title": "Misa Ilkhechi, The Co-Founder Story", "category": "Robotics", "date_short": "Sep 17, 2021", "hero": "/articles/misa-ilkhechi-the-co-founder-story/1631909867-misa-edited-edited.png"}, {"slug": "how-robots-can-solve-the-labor-crisis-in-manufacturing", "title": "How Robots Can Solve the Labor Crisis in Manufacturing", "category": "Robotics", "date_short": "Sep 14, 2021", "hero": "/articles/how-robots-can-solve-the-labor-crisis-in-manufacturing/1631637985-istock-1054184002.jpg"}, {"slug": "the-most-common-tasks-of-automation", "title": "The Most Common Tasks of Automation", "category": "Robotics", "date_short": "Sep 7, 2021", "hero": "/articles/the-most-common-tasks-of-automation/1631027166-shutterstock1664987644.jpg"}, {"slug": "when-buying-a-robot-doesnt-make-sense", "title": "Getting Started With Robotic Automation: 9 Questions To Ask", "category": "Robotics", "date_short": "Jul 23, 2021", "hero": "/articles/when-buying-a-robot-doesnt-make-sense/1614989106-machine-6.png"}, {"slug": "why-some-smaller-manufacturers-never-get-started-with-automation", "title": "Why Some Smaller Manufacturers Never Get Started With Automation", "category": "Robotics", "date_short": "Jun 22, 2021", "hero": "/articles/why-some-smaller-manufacturers-never-get-started-with-automation/1624374410-shutterstock1688533792.jpg"}, {"slug": "what-does-the-us-innovation-and-competition-act-mean-for-us-manufacturers", "title": "What Does the U.S. Innovation and Competition Act Mean for U.S. Manufacturers?", "category": "Robotics", "date_short": "Jun 11, 2021", "hero": "/articles/what-does-the-us-innovation-and-competition-act-mean-for-us-manufacturers/1623443207-gavel.jpg"}, {"slug": "robots-gone-wrong-volume-1", "title": "Robots Gone Wrong, Volume 1", "category": "Robotics", "date_short": "May 11, 2021", "hero": "/articles/robots-gone-wrong-volume-1/1620683847-shutterstock181473254.jpg"}, {"slug": "how-is-formic-different-from-other-robot-as-a-service-companies", "title": "How is Formic Different from other Robot-as-a-Service Companies?", "category": "Robotics", "date_short": "Apr 28, 2021", "hero": "/articles/how-is-formic-different-from-other-robot-as-a-service-companies/1619643379-istock-1071571038.jpg"}, {"slug": "which-is-a-better-deal-buying-or-renting-robots-by-the-hour", "title": "Which is a Better Deal - Buying or Renting Robots By-The-Hour?", "category": "Finance", "date_short": "Apr 26, 2021", "hero": "/articles/which-is-a-better-deal-buying-or-renting-robots-by-the-hour/1619453841-roi-image.jpeg"}, {"slug": "manufacturing-cfo-challenges-with-automation-part-2", "title": "Manufacturing CFO Challenges with Automation - Part 2", "category": "Finance", "date_short": "Apr 7, 2021", "hero": "/articles/manufacturing-cfo-challenges-with-automation-part-2/1617813895-istock-1252881116.jpg"}, {"slug": "manufacturing-cfo-challenges-with-automation-part-1", "title": "Manufacturing CFO Challenges with Automation - Part 1", "category": "Finance", "date_short": "Apr 1, 2021", "hero": "/articles/manufacturing-cfo-challenges-with-automation-part-1/1617314400-istock-1024245884.jpg"}, {"slug": "what-types-of-tasks-are-good-for-automation", "title": "What Types of Tasks Are Good For Automation?", "category": "Robotics", "date_short": "Mar 26, 2021", "hero": "/articles/what-types-of-tasks-are-good-for-automation/1616779716-1667788180-vector.jpg"}, {"slug": "you-build-things-we-can-help", "title": "You Build Things, We Can Help", "category": "Robotics", "date_short": "Mar 12, 2021", "hero": "/articles/you-build-things-we-can-help/1615513943-screen-shot-2021-03-11-at-5-51-34-pm.png"}];
const feat = stories.filter((x) => featured.includes(x.slug)).sort((a, b) => featured.indexOf(a.slug) - featured.indexOf(b.slug));
const rest = stories.filter((x) => !featured.includes(x.slug));
---
<Layout title="Articles — Formic" description="Insights, customer and event recaps, founder stories, and company news." ogTitle="Articles" ogDescription="Insights, customer and event recaps, founder stories, and company news.">
  <link rel="canonical" href="https://formic.co/articles" slot="head" />
  <style is:global slot="head">
    [data-card]{transition:background .2s ease}
    [data-card]:hover{background:var(--lgrey)}
    [data-card]:hover img{transform:scale(1.04)}
  </style>

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span>Articles
</div>

<section class="detail-hero">
  <div class="si">
    <div class="slabel" style="color:var(--orange)">Articles</div>
    <h1>Automation, <em>in practice</em>.</h1>
    <p class="lede">Insights, guides, event recaps, and company news from the production floors where automation is actually running.</p>
  </div>
</section>

{feat.length > 0 && (
  <section class="detail-block white" style="padding:80px 80px 0">
    <div style="max-width:1280px;margin:0 auto">
      <div class="db-tag">Featured</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:1px;background:var(--lgrey);border:1px solid var(--lgrey);margin-top:14px">
        {feat.map((s) => (
          <a data-card href={`/articles/${s.slug}`} style="display:flex;flex-direction:column;background:var(--white);text-decoration:none">
            <div style="aspect-ratio:16/9;overflow:hidden;background:var(--black)">
            {s.hero && s.hero.endsWith('.mp4')
              ? <video src={s.hero} autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;display:block"></video>
              : (s.hero ? <img src={s.hero} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease"/> : <span style="display:block;width:100%;height:100%"></span>)}
          </div>
          <div style="padding:18px 20px 22px;display:flex;flex-direction:column;gap:9px">
            <div style="font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange)">{s.date_short}</div>
            <div style="font-family:var(--sans);font-size:17px;font-weight:600;letter-spacing:-.01em;color:var(--black);line-height:1.28">{s.title}</div>
          </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<section class="detail-block white" style="padding:80px">
  <div id="rest-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--lgrey);max-width:1280px;margin:0 auto;border:1px solid var(--lgrey)">
    {rest.map((s, i) => (
      <a data-card data-i={i} href={`/articles/${s.slug}`} style={"flex-direction:column;background:var(--white);text-decoration:none;display:" + (i < 8 ? "flex" : "none")}>
        <div style="aspect-ratio:16/9;overflow:hidden;background:var(--black)">
            {s.hero && s.hero.endsWith('.mp4')
              ? <video src={s.hero} autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;display:block"></video>
              : (s.hero ? <img src={s.hero} alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease"/> : <span style="display:block;width:100%;height:100%"></span>)}
          </div>
          <div style="padding:18px 20px 22px;display:flex;flex-direction:column;gap:9px">
            <div style="font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--orange)">{s.date_short}</div>
            <div style="font-family:var(--sans);font-size:17px;font-weight:600;letter-spacing:-.01em;color:var(--black);line-height:1.28">{s.title}</div>
          </div>
      </a>
    ))}
  </div>
  {rest.length > 8 && (
    <div style="display:flex;justify-content:center;padding:44px 0 0">
      <button id="load-more" type="button" style="font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--black);background:var(--white);border:1px solid var(--lgrey);padding:14px 28px;cursor:pointer;display:inline-flex;align-items:center;gap:10px">Show more <span aria-hidden="true" style="color:var(--orange);font-size:14px;line-height:1">▾</span></button>
    </div>
  )}
</section>

<section class="detail-cta">
  <h2>Put automation <em>to work</em>.</h2>
  <div class="btn-row">
    <a href="/contact/get-a-quote" class="btn-ctadark">Get Started</a>
    <a href="/stories" class="btn-ctawh">Customer Stories</a>
  </div>
</section>

<script is:inline>
(function () {
  var grid = document.getElementById("rest-grid");
  var btn = document.getElementById("load-more");
  if (!grid || !btn) return;
  var cards = Array.prototype.slice.call(grid.querySelectorAll("[data-i]"));
  var shown = 8, step = 8;
  btn.addEventListener("click", function () {
    shown += step;
    cards.forEach(function (c) { if (Number(c.getAttribute("data-i")) < shown) c.style.display = "flex"; });
    if (shown >= cards.length) btn.style.display = "none";
  });
})();
</script>
</Layout>
