---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Articles — Formic"
  description="Automation insights, customer and event recaps, founder stories, and company news from Formic."
  ogTitle="Formic Articles"
  ogDescription="Automation insights and news from Formic."
>
  <link rel="canonical" href="https://formic.co/articles" slot="head" />
