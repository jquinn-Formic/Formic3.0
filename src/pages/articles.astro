    [data-article-card]{transition:background .2s ease}
    [data-article-card]:hover{background:var(--lgrey)}
    [data-article-card]:hover img{transform:scale(1.04)}
  </style>

<div class="detail-bc">
  <a href="/">Home</a><span class="sep">/</span>Articles
</div>

<section class="detail-hero">
