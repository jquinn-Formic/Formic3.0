---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Automation Solutions — Formic" description="End-of-line packing, precision part manufacturing, and general task automation — all available as a service.">
  <style is:global slot="head">
.sol-hero-grid{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:55vh 35vh;gap:2px}
.sol-hero-cell{overflow:hidden;position:relative}
.sol-hero-cell img,.sol-hero-cell video{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s}
.sol-hero-cell:hover img,.sol-hero-cell:hover video{transform:scale(1.03)}
.sol-hero-cell.tall{grid-row:span 2}
.sol-hero-overlay{position:absolute;bottom:0;left:0;right:0;padding:28px 32px;background:linear-gradient(to top,rgba(9,21,23,.75),transparent)}
.sol-hero-label{font-family:var(--mono);font-size:10px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:rgba(240,245,241,.75)}
.sol-section{display:grid;grid-template-columns:1fr 1fr;gap:0;background:var(--lgrey);margin-bottom:2px}
.sol-text{padding:72px 64px}
.sol-img{overflow:hidden}
.sol-img img,.sol-img video{width:100%;height:100%;object-fit:cover;display:block;min-height:480px}
.sol-text h2{font-family:var(--sans);font-size:clamp(36px,3.5vw,52px);font-weight:500;letter-spacing:-.02em;color:var(--black);line-height:1.05;margin-bottom:16px}
.sol-text .btext{margin-bottom:28px}
.spec-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:28px}
.spec-item{background:var(--lgrey);padding:14px 16px}
.spec-item dt{font-family:var(--mono);font-size:9px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--orange);margin-bottom:4px}
.spec-item dd{font-family:var(--sans);font-size:14px;font-weight:400;color:var(--black)}
.gif-fullbleed{width:100%;height:50vh;object-fit:cover;display:block}
@media(max-width:900px){.sol-hero-grid{grid-template-columns:1fr;grid-template-rows:auto}.sol-hero-cell.tall{grid-row:span 1}.sol-section{grid-template-columns:1fr}.sol-text{padding:40px 24px}.spec-grid{grid-template-columns:1fr}}
  </style>

<!-- HERO: image mosaic -->
<div style="padding-top:64px">
  <div class="sol-hero-grid">
    <div class="sol-hero-cell tall">
      <img src="/Focus-7603.jpg" alt="Formic industrial palletizer in CPG facility">
      <div class="sol-hero-overlay"><span class="sol-hero-label">End-of-line packing</span></div>
    </div>
    <div class="sol-hero-cell">
      <img src="/Talos-0095.jpg" alt="Formic white cobot arm for precision manufacturing">
      <div class="sol-hero-overlay"><span class="sol-hero-label">Precision manufacturing</span></div>
    </div>
    <div class="sol-hero-cell">
      <img src="/Talos-0143.jpg" alt="Formic robot in motion — general tasks">
      <div class="sol-hero-overlay"><span class="sol-hero-label">General tasks</span></div>
    </div>
  </div>
</div>

<!-- INTRO -->
<section class="bg-white">
  <div class="si">
    <div class="two-col rv" style="align-items:end">
      <div>
        <div class="slabel">Solutions</div>
        <h2 class="dtitle">Built for<br><em>your line</em></h2>
      </div>
      <p class="btext">Standardized, modular systems for the most demanding tasks on mid-market CPG floors. Pre-engineered designs deployed in weeks — not months of custom work.</p>
    </div>
  </div>
</section>

<!-- EOL PACKING -->
<section id="eol" class="bg-white" style="padding-top:2px">
  <div class="sol-section rv">
    <div class="sol-text bg-white">
      <div class="slabel">01 — End-of-Line Packing</div>
      <h2>Palletizing,<br>packing, sealing.</h2>
      <p class="btext">From individual case packing to full-pallet stacking — Formic's end-of-line systems handle the most physically demanding, repetitive tasks with consistent precision, 24 hours a day.</p>
      <div class="spec-grid">
        <div class="spec-item"><dt>Stack height</dt><dd>Up to 95" (industrial)</dd></div>
        <div class="spec-item"><dt>Case dimensions</dt><dd>Up to 24" × 16" × 15"</dd></div>
        <div class="spec-item"><dt>Throughput</dt><dd>Up to 10 cases/min</dd></div>
        <div class="spec-item"><dt>Case weight</dt><dd>Up to 40 lbs</dd></div>
        <div class="spec-item"><dt>Pack rates</dt><dd>Up to 120 units/min</dd></div>
        <div class="spec-item"><dt>Footprint</dt><dd>As compact as 8'×8'×7'</dd></div>
      </div>
      <div class="stags" style="margin-bottom:28px">
        <span class="stag">Industrial Palletizing</span>
        <span class="stag">Cobot Palletizing</span>
        <span class="stag">Case Packing</span>
        <span class="stag">Case Erecting</span>
        <span class="stag">Case Sealing</span>
        <span class="stag">AMRs</span>
        <span class="stag">Slip Sheet Placement</span>
      </div>
      <a href="/company#demo" class="larr">Scope my application →</a>
    </div>
    <div class="sol-img">
      <img src="/R52_8950-2.jpg" alt="Formic KUKA industrial palletizer with EOAT" loading="lazy">
    </div>
  </div>
</section>

<!-- GIF break — palletizing in action -->
<div class="rv">
  <img src="/Haviland_Products_-_Palletizing.gif" class="gif-fullbleed" alt="Formic palletizer running at production speed" style="height:45vh">
</div>

<!-- CASE PACKING in action -->
<div class="rv" style="margin-top:2px">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--lgrey)">
    <div style="overflow:hidden">
      <img src="/CasepackerPromoVideo_NoText.gif" style="width:100%;height:380px;object-fit:cover;display:block" alt="Formic case packer processing product at speed">
    </div>
    <div style="background:var(--dgrey);padding:48px 44px;display:flex;flex-direction:column;justify-content:center">
      <div class="slabel" style="color:var(--orange)">Industrial Case Packing</div>
      <h3 style="font-family:var(--sans);font-size:28px;font-weight:500;letter-spacing:-.01em;color:var(--white);margin-bottom:14px">Jars. Cans. Canisters.<br>Bottles. Tubs. Bowls.</h3>
      <p style="font-size:14px;font-weight:300;color:rgba(240,245,241,.45);line-height:1.7;margin-bottom:24px">Rigid packaging types handled with precision. Up to 120 units/minute in a compact 8'×8'×7' footprint designed for end-of-line integration.</p>
      <a href="/company#demo" class="larr">Get a quote →</a>
    </div>
  </div>
</div>

<!-- EOAT DETAIL -->
<div class="rv" style="margin-top:2px">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--lgrey)">
    <div style="background:var(--white);padding:48px 44px;display:flex;flex-direction:column;justify-content:center">
      <div class="slabel">End-of-Arm Tooling</div>
      <h3 style="font-family:var(--sans);font-size:28px;font-weight:500;letter-spacing:-.01em;color:var(--black);margin-bottom:14px">EOAT matched<br>to your product</h3>
      <p style="font-size:14px;font-weight:300;color:var(--mgrey);line-height:1.7;margin-bottom:24px">Vacuum, bottom-support, and clamp configurations — each selected and tested specifically for your product's shape, weight, and surface properties. No guess work.</p>
      <div class="stags">
        <span class="stag">Vacuum EOAT</span>
        <span class="stag">Bottom Support</span>
        <span class="stag">Clamp</span>
        <span class="stag">Custom configs</span>
      </div>
    </div>
    <div style="overflow:hidden">
      <img src="/R52_5904-2.jpg" style="width:100%;height:380px;object-fit:cover;display:block" alt="Formic KPA EOAT gripper close-up detail" loading="lazy">
    </div>
  </div>
</div>

<!-- VIDEO SPLIT: ZzWbNn-EU_0 — Full Service in action -->
<section class="bg-lgrey rv" style="padding:0;margin-top:48px">
  <div class="video-split">
    <div class="yt-facade" data-ytid="ZzWbNn-EU_0" onclick="loadYT(this)">
      <img
        src="https://i.ytimg.com/vi/ZzWbNn-EU_0/maxresdefault.jpg"
        alt="Formic Full Service Automation in action"
        loading="lazy"
        onerror="this.src='/Focus-7603.jpg'"
      >
      <div class="yt-play"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
      <span class="yt-label">Watch: Full Service Automation</span>
    </div>
    <div class="vs-text light" style="background:var(--white)">
      <div class="slabel">See It Running</div>
      <h2 class="dk">Your line.<br><em>Our system.</em></h2>
      <p class="vs-body dk">Watch a live Formic deployment — from scoping to commissioning to full production. End-of-line automation, running the way it should.</p>
      <a href="/full-service" class="larr">How Full Service works →</a>
    </div>
  </div>
</section>

<!-- PRECISION MFG -->
<section id="precision" class="bg-lgrey" style="margin-top:48px">
  <div class="sol-section rv" style="background:var(--lgrey)">
    <div class="sol-img" style="background:var(--white)">
      <img src="/Talos-0095.jpg" alt="Formic cobot arm for precision manufacturing tasks" loading="lazy" style="min-height:480px;width:100%;object-fit:cover">
    </div>
    <div class="sol-text" style="background:var(--white)">
      <div class="slabel">02 — Precision Part Manufacturing</div>
      <h2>Machine tending<br>without the risk.</h2>
      <p class="btext">Replace the most repetitive, ergonomically damaging tasks in your precision manufacturing operation. Mill tending, lathe tending, and injection molding — handled with the same consistent precision every cycle.</p>
      <div class="stags" style="margin-bottom:28px">
        <span class="stag">Mill Machine Tending</span>
        <span class="stag">Lathe Machine Tending</span>
        <span class="stag">Injection Molding Tending</span>
      </div>
      <ul class="feat-list" style="list-style:none;margin-bottom:28px">
        <li style="font-size:14px;font-weight:300;color:var(--dgrey);padding:10px 0;border-bottom:1px solid var(--lgrey);display:flex;align-items:baseline;gap:10px;line-height:1.5"><span style="width:5px;height:5px;background:var(--orange);border-radius:50%;flex-shrink:0;display:block;margin-top:6px"></span>Collaborative and industrial robot options depending on floor layout and throughput</li>
        <li style="font-size:14px;font-weight:300;color:var(--dgrey);padding:10px 0;border-bottom:1px solid var(--lgrey);display:flex;align-items:baseline;gap:10px;line-height:1.5"><span style="width:5px;height:5px;background:var(--orange);border-radius:50%;flex-shrink:0;display:block;margin-top:6px"></span>Frees skilled machinists from loading/unloading to focus on quality and programming</li>
        <li style="font-size:14px;font-weight:300;color:var(--dgrey);padding:10px 0;display:flex;align-items:baseline;gap:10px;line-height:1.5"><span style="width:5px;height:5px;background:var(--orange);border-radius:50%;flex-shrink:0;display:block;margin-top:6px"></span>Eliminates repetitive strain injuries associated with machine tending positions</li>
      </ul>
      <a href="/company#demo" class="larr">Scope my application →</a>
    </div>
  </div>
</section>

<!-- GENERAL TASKS -->
<section id="general" class="bg-black" style="padding:72px 0 0">
  <div class="si rv" style="padding-bottom:52px">
    <div class="slabel" style="color:var(--orange)">03 — General Tasks</div>
    <h2 class="dtitle wh" style="margin-bottom:20px">The next frontier<br><em>available now</em></h2>
    <p class="btext wh" style="max-width:560px">Mobile bimanual manipulators and full humanoid platforms bring flexible, general-purpose automation to tasks that were previously impossible to automate. Formic's Full Service model means you can deploy these systems today — without the capital risk of figuring it out yourself.</p>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(240,245,241,.08)" class="rv d1">
    <div style="background:var(--ink2,#1A1917);padding:48px 44px">
      <div class="slabel" style="color:var(--orange)">Mobile Bimanual Manipulator</div>
      <h3 style="font-family:var(--sans);font-size:24px;font-weight:500;color:var(--white);letter-spacing:-.01em;margin-bottom:12px">Two arms. Wheels. Purpose.</h3>
      <p style="font-size:14px;font-weight:300;color:rgba(240,245,241,.4);line-height:1.7">Mobile platforms with dual-arm manipulation capability for tasks requiring dexterity and mobility across your facility — not just a fixed workstation.</p>
    </div>
    <div style="background:var(--ink2,#1A1917);padding:48px 44px">
      <div class="slabel" style="color:var(--orange)">Full Humanoids</div>
      <h3 style="font-family:var(--sans);font-size:24px;font-weight:500;color:var(--white);letter-spacing:-.01em;margin-bottom:12px">Human form. Machine endurance.</h3>
      <p style="font-size:14px;font-weight:300;color:rgba(240,245,241,.4);line-height:1.7">Full bipedal humanoid platforms that can perform a wide range of general manufacturing tasks in environments designed for humans — no facility modifications needed.</p>
    </div>
  </div>
  <div class="fullbleed-wrap" style="margin-top:2px">
    <img src="/Talos-0143.jpg" style="width:100%;height:50vh;object-fit:cover;display:block;filter:brightness(.7)" alt="Formic robot in motion — next generation automation">
    <div class="fullbleed-caption">The future of manufacturing automation — available today</div>
  </div>
</section>

<!-- CTA -->
<div class="cta-band rv">
  <h2>Not sure which<br>system fits your line?</h2>
  <div class="cta-band-btns">
    <a href="/company#demo" class="btn-dark">Get a Demo</a>
    <a href="/full-service" class="btn-wh-border">How It Works</a>
  </div>
</div>

  <script is:inline slot="scripts">
function loadYT(el){
  const id=el.dataset.ytid;
  const w=document.createElement('div');
  w.className='vs-embed fill';
  w.innerHTML=`<iframe src="https://www.youtube.com/embed/${id}?autoplay=1&rel=0&modestbranding=1" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy" title="Formic video"></iframe>`;
  el.replaceWith(w);
}
  </script>
</Layout>
